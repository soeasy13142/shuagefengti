.page {
  background-color: #faf9f5;
  min-height: 100vh;
  padding: 24rpx;
  font-family: -apple-system, BlinkMacSystemFont, Georgia, 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
  color: #141413;
}

.band-label {
  display: block;
  font-family: Georgia, 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
  font-size: 30rpx;
  letter-spacing: -3rpx;
  color: #141413;
  margin-bottom: 16rpx;
}

.input-band,
.avalanche-band,
.control-band,
.w-band,
.compress-band,
.hash-band {
  background-color: #efe9de;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.message-input {
  width: 100%;
  background-color: #faf9f5;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #141413;
  min-height: 96rpx;
  box-sizing: border-box;
}

.input-meta {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
  margin-bottom: 16rpx;
}

.meta-label {
  font-size: 22rpx;
  color: #6c6a64;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.btn-primary {
  flex: 2;
  background-color: #cc785c;
  color: #faf9f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  border: none;
}

.btn-secondary {
  flex: 1;
  background-color: #faf9f5;
  color: #141413;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  border: 1rpx solid #d4cfc2;
}

.btn-small {
  flex: 0 0 auto;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  min-width: 80rpx;
}

.btn-hover {
  opacity: 0.7;
}

.avalanche-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.avalanche-text {
  font-size: 26rpx;
  color: #6c6a64;
  width: 160rpx;
}

.avalanche-value {
  font-size: 26rpx;
  color: #141413;
  font-family: monospace;
}

.avalanche-diff {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #d4cfc2;
}

.diff-text {
  display: block;
  font-size: 26rpx;
  color: #141413;
  margin-bottom: 12rpx;
}

.diff-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 2rpx;
}

.diff-bit {
  width: 10rpx;
  height: 24rpx;
}

.control-band {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.round-counter {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #6c6a64;
}

.speed-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.speed-label {
  font-size: 22rpx;
  color: #6c6a64;
}

.speed-picker {
  background-color: #faf9f5;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #141413;
}

.picker-arrow {
  color: #6c6a64;
  font-size: 20rpx;
}

.w-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.w-cell {
  width: calc(12.5% - 6rpx);
  background-color: #faf9f5;
  border-radius: 8rpx;
  padding: 8rpx 4rpx;
  text-align: center;
  border: 1rpx solid transparent;
  box-sizing: border-box;
}

.w-cell-active {
  border-color: #cc785c;
  background-color: #f5ede2;
}

.w-index {
  display: block;
  font-size: 18rpx;
  color: #6c6a64;
}

.w-value {
  display: block;
  font-size: 20rpx;
  color: #141413;
  font-family: monospace;
}

.register-row {
  display: flex;
  align-items: center;
  padding: 6rpx 0;
  border-bottom: 1rpx solid #d4cfc2;
}

.register-label {
  width: 60rpx;
  font-family: Georgia, 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
  font-size: 28rpx;
  color: #cc785c;
}

.register-value {
  flex: 1;
  font-family: monospace;
  font-size: 26rpx;
  color: #141413;
}

.formula-block {
  background-color: #faf9f5;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  margin-top: 12rpx;
  border-left: 4rpx solid #cc785c;
}

.formula-label {
  display: inline-block;
  width: 80rpx;
  font-family: Georgia, 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
  font-size: 24rpx;
  color: #cc785c;
  margin-right: 8rpx;
}

.formula-text {
  font-family: monospace;
  font-size: 24rpx;
  color: #141413;
}

.hash-band {
  background-color: #181715;
  color: #faf9f5;
}

.hash-band .band-label {
  color: #faf9f5;
}

.hash-final {
  padding: 16rpx 0;
}

.hash-prefix {
  display: block;
  font-family: Georgia, 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
  font-size: 26rpx;
  color: #efe9de;
  margin-bottom: 12rpx;
}

.hash-value {
  display: block;
  font-family: monospace;
  font-size: 26rpx;
  color: #faf9f5;
  word-break: break-all;
  line-height: 1.6;
}

/* ── ℹ︎ 介绍按钮 ── */
.info-btn {
  position: fixed;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: #efe9de;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  opacity: 0.8;
}
.info-btn:active {
  opacity: 0.5;
}
.info-btn-icon {
  font-size: 28rpx;
  color: #6c6a64;
}

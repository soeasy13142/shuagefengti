/* ── 字体栈（CSS 变量，可在各页面按需覆写） ── */
page {
  --font-sans: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  --font-serif: Georgia, 'Times New Roman', 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
  --font-mono: 'SF Mono', 'Menlo', 'Consolas', 'Courier New', 'Noto Sans Mono', monospace;

  font-family: var(--font-sans);
  font-size: 28rpx;
  color: #1a1a2e;
  background-color: #faf9f5;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

.container {
  padding: 30rpx;
  padding-bottom: 180rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 2rpx;
}

.btn-primary::after { border: none; }

.btn-secondary {
  background: #fff;
  color: #07c160;
  border: 2rpx solid rgba(7, 193, 96, 0.3);
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.tag {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  letter-spacing: 1rpx;
}

.tag-green {
  background: rgba(7, 193, 96, 0.1);
  color: #07c160;
}

.tag-gray {
  background: rgba(0, 0, 0, 0.04);
  color: #999;
}

.tag-red {
  background: rgba(230, 67, 64, 0.1);
  color: #e64340;
}

.tag-blue {
  background: rgba(24, 144, 255, 0.1);
  color: #1890ff;
}

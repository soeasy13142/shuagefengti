/* ═══════════════════════════════════════════
   Claude Design — 首页
   暖奶油画布 · 衬线标题 · 珊瑚主色
   ═══════════════════════════════════════════ */

/* ── 入场动画 ── */
@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateY(30rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(50rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.anim-in       { animation: fadeSlideIn 0.5s ease-out both; }
.anim-up       { animation: fadeSlideUp 0.5s ease-out 0.2s both; }
.anim-up-delay { animation: fadeSlideUp 0.5s ease-out 0.35s both; }

/* ── 页面画布 ── */
.page {
  min-height: 100vh;
  background: #faf9f5;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ═══════════════════════════════════════════
   Hero — 奶油画布 + 衬线大标题
   ═══════════════════════════════════════════ */
.hero-band {
  background: #faf9f5;
  padding: 96rpx 56rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0;
}

.hero-title {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 72rpx;
  font-weight: 400;
  color: #141413;
  line-height: 1.05;
  letter-spacing: -3rpx;
  margin-bottom: 20rpx;
}

.hero-tagline {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  font-weight: 400;
  color: #6c6a64;
  line-height: 1.55;
  margin-bottom: 56rpx;
}

/* 主 CTA — 珊瑚色矩形 */
.hero-cta {
  width: 100%;
  max-width: 560rpx;
  height: 88rpx;
  background: #cc785c;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.hero-cta:active,
.tapped {
  background: #a9583e;
}

.cta-hover {
  background: #a9583e;
}

.cta-text {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
  line-height: 1;
}

.hero-sub {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  font-weight: 400;
  color: #8e8b82;
  letter-spacing: 0;
}

/* ═══════════════════════════════════════════
   工具区 — 奶油卡片
   ═══════════════════════════════════════════ */
.tools-band {
  background: #faf9f5;
  padding: 0 32rpx 64rpx;
  opacity: 0;
}

.band-label {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  font-weight: 500;
  color: #6c6a64;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin-bottom: 24rpx;
  padding-left: 4rpx;
}

.tool-grid {
  display: flex;
  gap: 20rpx;
}

.tool-card {
  flex: 1;
  background: #efe9de;
  border: none;
  border-radius: 24rpx;
  padding: 32rpx 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* 学习驾驶舱全宽卡片 */
.tool-card-full {
  margin-bottom: 20rpx;
  padding: 28rpx 28rpx;
}

.tool-full-row {
  display: flex;
  align-items: center;
}

.tool-full-row .tool-icon {
  font-size: 48rpx;
  margin-bottom: 0;
  margin-right: 20rpx;
}

.tool-full-info {
  flex: 1;
}

.tool-full-info .tool-name {
  padding: 0;
  margin-bottom: 4rpx;
}

.tool-desc {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 22rpx;
  font-weight: 400;
  color: #6c6a64;
}

.tool-card:active {
  background: #e8e0d2;
}

.tool-hover {
  background: #e8e0d2;
}

.tool-disabled {
  opacity: 0.45;
}

.tool-icon {
  font-size: 48rpx;
  margin-bottom: 20rpx;
}

.tool-name {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 30rpx;
  font-weight: 500;
  color: #141413;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.tool-tag {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 22rpx;
  font-weight: 400;
  color: #6c6a64;
}

.tool-link {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  font-weight: 500;
  color: #cc785c;
}

/* ═══════════════════════════════════════════
   快捷入口 — 奶油卡片
   ═══════════════════════════════════════════ */
.shortcuts-band {
  background: #efe9de;
  margin: 0 32rpx;
  border-radius: 24rpx;
  padding: 0 32rpx;
  opacity: 0;
}

.shortcut-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 0;
}

.shortcut-row:active {
  opacity: 0.6;
}

.row-hover {
  opacity: 0.6;
}

.row-divider {
  height: 1rpx;
  background: #e6dfd8;
}

.shortcut-label {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  font-weight: 500;
  color: #141413;
  letter-spacing: 0;
}

.shortcut-arrow {
  font-size: 36rpx;
  color: #6c6a64;
  font-weight: 400;
}

/* ═══════════════════════════════════════════
   备案号
   ═══════════════════════════════════════════ */
.footer {
  background: #faf9f5;
  padding: 56rpx 0 40rpx;
  text-align: center;
}

.icp {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 22rpx;
  font-weight: 400;
  color: #8e8b82;
  letter-spacing: 0;
}

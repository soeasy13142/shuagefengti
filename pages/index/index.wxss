/* BMW Corporate Design — 首页 */

/* 入场动画 */
@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(50rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.anim-in {
  animation: fadeSlideIn 0.5s ease-out both;
}

.anim-up {
  animation: fadeSlideUp 0.5s ease-out 0.2s both;
}

.anim-up-delay {
  animation: fadeSlideUp 0.5s ease-out 0.35s both;
}

/* 页面 */
.page {
  min-height: 100vh;
  background: #ffffff;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ──────────────────────────────────
   深色 Hero Band
   ────────────────────────────────── */
.hero-band {
  background: #1a2129;
  padding: 80rpx 48rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0;
}

.hero-title {
  font-size: 64rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.05;
  letter-spacing: 0;
  margin-bottom: 16rpx;
}

.hero-tagline {
  font-size: 28rpx;
  font-weight: 300;
  color: #bbbbbb;
  line-height: 1.55;
  margin-bottom: 48rpx;
}

/* 主 CTA — BMW 矩形按钮 */
.hero-cta {
  width: 100%;
  height: 96rpx;
  background: #1c69d4;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.hero-cta:active,
.tapped {
  background: #0653b6;
}

.cta-hover {
  background: #0653b6;
}

.cta-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.hero-sub {
  font-size: 24rpx;
  font-weight: 300;
  color: #9a9a9a;
  letter-spacing: 0;
}

/* ──────────────────────────────────
   工具区：白色画布
   ────────────────────────────────── */
.tools-band {
  background: #ffffff;
  padding: 64rpx 48rpx;
  opacity: 0;
}

.band-label {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #262626;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin-bottom: 32rpx;
}

.tool-grid {
  display: flex;
  gap: 20rpx;
}

.tool-card {
  flex: 1;
  background: #ffffff;
  border: 1rpx solid #e6e6e6;
  padding: 0;
  display: flex;
  flex-direction: column;
  position: relative;
}

.tool-card:active {
  border-color: #262626;
}

.tool-hover {
  border-color: #262626;
}

.tool-disabled {
  opacity: 0.45;
}

.tool-photo {
  background: #fafafa;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-icon {
  font-size: 56rpx;
}

.tool-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #262626;
  padding: 20rpx 20rpx 8rpx;
  line-height: 1.4;
}

.tool-tag {
  display: block;
  font-size: 22rpx;
  font-weight: 300;
  color: #6b6b6b;
  padding: 0 20rpx 20rpx;
}

.tool-link {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #262626;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  padding: 0 20rpx 24rpx;
}

/* ──────────────────────────────────
   快捷入口
   ────────────────────────────────── */
.shortcuts-band {
  background: #f7f7f7;
  padding: 0 48rpx;
  opacity: 0;
}

.shortcut-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 0;
}

.shortcut-row:active {
  opacity: 0.6;
}

.row-hover {
  opacity: 0.6;
}

.row-divider {
  height: 1rpx;
  background: #e6e6e6;
}

.shortcut-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #262626;
  letter-spacing: 0;
}

.shortcut-arrow {
  font-size: 36rpx;
  color: #6b6b6b;
  font-weight: 300;
}

/* ──────────────────────────────────
   备案号
   ────────────────────────────────── */
.footer {
  background: #ffffff;
  padding: 48rpx 0 32rpx;
  text-align: center;
}

.icp {
  font-size: 22rpx;
  font-weight: 300;
  color: #9a9a9a;
  letter-spacing: 0;
}

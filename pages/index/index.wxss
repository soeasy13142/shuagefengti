/* ═══════════════════════════════════════════
   Claude Design — 首页
   暖奶油画布 · 衬线标题 · 珊瑚主色
   ═══════════════════════════════════════════ */

/* ── 入场动画 ── */
@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateY(30rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(50rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.anim-in       { animation: fadeSlideIn 0.5s ease-out both; }
.anim-up       { animation: fadeSlideUp 0.5s ease-out 0.2s both; }
.anim-up-delay { animation: fadeSlideUp 0.5s ease-out 0.35s both; }

/* ── 页面画布 ── */
.page {
  min-height: 100vh;
  background: #faf9f5;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ═══════════════════════════════════════════
   Hero — 奶油画布 + 衬线大标题
   ═══════════════════════════════════════════ */
.hero-band {
  background: #faf9f5;
  padding: 96rpx 56rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0;
}

.hero-title {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 72rpx;
  font-weight: 400;
  color: #141413;
  line-height: 1.05;
  letter-spacing: -3rpx;
  margin-bottom: 20rpx;
}

.hero-tagline {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  font-weight: 400;
  color: #6c6a64;
  line-height: 1.55;
  margin-bottom: 56rpx;
}

/* 主 CTA — 珊瑚色矩形 */
.hero-cta {
  width: 100%;
  max-width: 560rpx;
  height: 88rpx;
  background: #cc785c;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.hero-cta:active,
.tapped {
  background: #a9583e;
}

.cta-hover {
  background: #a9583e;
}

.cta-text {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
  line-height: 1;
}

.hero-sub {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  font-weight: 400;
  color: #8e8b82;
  letter-spacing: 0;
}

/* ═══════════════════════════════════════════
   Zone 2 — 学习状态条
   ═══════════════════════════════════════════ */
.stats-band {
  background: #faf9f5;
  padding: 0 32rpx 48rpx;
  opacity: 0;
}

.stats-card {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 24rpx;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.stats-title {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
  font-size: 26rpx;
  font-weight: 600;
  color: #141413;
}

.stats-link {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
  font-size: 24rpx;
  font-weight: 500;
  color: #cc785c;
}

.stats-grid {
  display: flex;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  display: block;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 44rpx;
  font-weight: 400;
  color: #cc785c;
  line-height: 1.1;
}

.stats-label {
  display: block;
  margin-top: 8rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
  font-size: 20rpx;
  font-weight: 400;
  color: #6c6a64;
}

.stats-empty {
  padding: 16rpx 0;
  text-align: center;
}

.stats-empty-text {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
  font-size: 24rpx;
  color: #8e8b82;
}

/* ═══════════════════════════════════════════
   Zone 3 — 工具箱
   ═══════════════════════════════════════════ */
.tools-band {
  background: #faf9f5;
  padding: 0 32rpx 64rpx;
  opacity: 0;
}

.band-label {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  font-weight: 500;
  color: #6c6a64;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin-bottom: 24rpx;
  padding-left: 4rpx;
}

/* ── 分类标签栏 ── */
.category-tabs {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.category-tab {
  display: inline-block;
  padding: 14rpx 24rpx;
  margin-right: 12rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
  font-size: 26rpx;
  font-weight: 500;
  color: #6c6a64;
  border-bottom: 4rpx solid transparent;
  transition: color 0.2s, border-color 0.2s;
}

.category-tab.active {
  color: #cc785c;
  border-bottom-color: #cc785c;
}

/* ── 分类分组（全部工具视图） ── */
.cat-section {
  margin-bottom: 28rpx;
}

.cat-section:first-child {
  margin-top: 0;
}

.sub-label {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 22rpx;
  font-weight: 500;
  color: #8e8b82;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

/* ── 工具卡片网格 ── */
.tool-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tool-card {
  flex: 1;
  min-width: 0;
  background: #efe9de;
  border: none;
  border-radius: 24rpx;
  padding: 32rpx 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  position: relative;
  box-sizing: border-box;
}

.tool-card:active {
  background: #e8e0d2;
}

.tool-hover {
  background: #e8e0d2;
}

.tool-disabled {
  opacity: 0.40;
}

.tool-icon {
  font-size: 48rpx;
  margin-bottom: 20rpx;
}

.tool-name {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 30rpx;
  font-weight: 500;
  color: #141413;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.tool-desc {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
  font-size: 20rpx;
  font-weight: 400;
  color: #8e8b82;
  line-height: 1.4;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-link {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  font-weight: 500;
  color: #cc785c;
}

.tool-tag {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 22rpx;
  font-weight: 400;
  color: #6c6a64;
}

/* ── 即将推出：紧凑列表 ── */

.coming-soon-list {
  background: #efe9de;
  border-radius: 24rpx;
  overflow: hidden;
}

.coming-soon-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.coming-soon-item:last-child {
  border-bottom: none;
}

.cs-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
  opacity: 0.45;
  flex-shrink: 0;
}

.cs-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.cs-name {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
  font-size: 28rpx;
  font-weight: 500;
  color: #141413;
  opacity: 0.45;
}

.cs-desc {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
  font-size: 22rpx;
  color: #8e8b82;
  opacity: 0.5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cs-tag {
  flex-shrink: 0;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
  font-size: 20rpx;
  color: #8e8b82;
  opacity: 0.5;
  margin-left: 16rpx;
}

.empty-cat {
  padding: 48rpx 0;
  text-align: center;
}

.empty-cat-text {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
  font-size: 26rpx;
  color: #8e8b82;
}

/* ═══════════════════════════════════════════
   快捷入口 — 奶油卡片
   ═══════════════════════════════════════════ */
.shortcuts-band {
  background: #efe9de;
  margin: 0 32rpx;
  border-radius: 24rpx;
  padding: 0 32rpx;
  opacity: 0;
}

.shortcut-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 0;
}

.shortcut-row:active {
  opacity: 0.6;
}

.row-hover {
  opacity: 0.6;
}

.row-divider {
  height: 1rpx;
  background: #e6dfd8;
}

.shortcut-label {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  font-weight: 500;
  color: #141413;
  letter-spacing: 0;
}

.shortcut-arrow {
  font-size: 36rpx;
  color: #6c6a64;
  font-weight: 400;
}

/* ═══════════════════════════════════════════
   备案号
   ═══════════════════════════════════════════ */
.footer {
  background: #faf9f5;
  padding: 56rpx 0 40rpx;
  text-align: center;
}

.icp {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 22rpx;
  font-weight: 400;
  color: #8e8b82;
  letter-spacing: 0;
}

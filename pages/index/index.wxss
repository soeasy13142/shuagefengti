/* ═══════════════════════════════════════════
   Claude Design — 首页（重设计 v2）
   工具箱优先 · 紧凑头部 · 大网格卡片
   ═══════════════════════════════════════════ */

@import "../styles/tools-shared.wxss";

/* ── 入场动画 ── */
@keyframes fadeSlideIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(50rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.anim-in       { animation: fadeSlideIn 0.4s ease-out both; }
.anim-up       { animation: fadeSlideUp 0.5s ease-out 0.2s both; }
.anim-up-delay { animation: fadeSlideUp 0.5s ease-out 0.35s both; }

/* ── 页面画布 ── */
.page {
  min-height: 100vh;
  background: #faf9f5;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ═══════════════════════════════════════════
   顶部品牌 + 刷题入口
   ═══════════════════════════════════════════ */
.top-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
  background: #faf9f5;
  opacity: 0;
}

.brand-title {
  display: block;
  font-family: Georgia, 'Times New Roman', 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
  font-size: 48rpx;
  font-weight: 400;
  color: #141413;
  line-height: 1.05;
  letter-spacing: -3rpx;
  margin-bottom: 28rpx;
  text-align: center;
}

.brand-cta {
  display: inline-block;
  background: #cc785c;
  border-radius: 12rpx;
  padding: 10rpx 28rpx;
  margin-bottom: 16rpx;
}

.brand-cta:active,
.cta-hover {
  background: #a9583e;
}

.cta-text {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 26rpx;
  font-weight: 500;
  color: #ffffff;
  line-height: 1.4;
}

.brand-links {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.brand-link {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', sans-serif;
  font-size: 24rpx;
  font-weight: 400;
  color: #6c6a64;
  line-height: 1.4;
}

.brand-link:active {
  opacity: 0.6;
}

.brand-dot {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', sans-serif;
  font-size: 24rpx;
  color: #6c6a64;
}

/* ═══════════════════════════════════════════
   工具箱区域
   ═══════════════════════════════════════════ */
.tools-area {
  padding: 0 32rpx 40rpx;
  background: #faf9f5;
  opacity: 0;
}

/* ── 头部行：标签栏 + 模式切换 ── */
.tools-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

/* ── 胶囊式模式切换 ── */
.mode-capsule {
  display: flex;
  flex-direction: row;
  border: 2rpx solid #d0ccc0;
  border-radius: 14rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.mode-capsule-item {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', sans-serif;
  font-size: 22rpx;
  font-weight: 500;
  color: #6c6a64;
  padding: 8rpx 20rpx;
  line-height: 1.4;
  text-align: center;
  transition: background 0.2s, color 0.2s;
}

.mode-capsule-item.active {
  background: #cc785c;
  color: #ffffff;
}

.mode-capsule-item:not(.active):active {
  background: #e8e0d2;
}

/* ── 分类标签栏 ── */
.category-tabs {
  white-space: nowrap;
  margin-bottom: 0;
  flex: 1;
  min-width: 0;       /* 防止 flex 溢出 */
}

.category-tab {
  display: inline-block;
  padding: 14rpx 24rpx;
  margin-right: 12rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', sans-serif;
  font-size: 26rpx;
  font-weight: 500;
  color: #6c6a64;
  border-bottom: 4rpx solid transparent;
  transition: color 0.2s, border-bottom-color 0.2s;
}

.category-tab.active {
  color: #cc785c;
  border-bottom-color: #cc785c;
}


/* ── 精选预告网格 ── */
.preview-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

/* ── 分类标题 ── */
.cat-section-title {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  font-weight: 500;
  color: #8e8b82;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.cat-section {
  margin-bottom: 8rpx;
}

.cat-section:first-child {
  margin-top: 0;
}

/* ── 查看全部链接 ── */
.view-all {
  padding: 32rpx 0;
  text-align: center;
}

.view-all:active {
  opacity: 0.6;
}

.view-all-text {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 26rpx;
  font-weight: 500;
  color: #cc785c;
}

/* ── 全空状态 ── */
.empty-cat {
  padding: 64rpx 0;
  text-align: center;
}

.empty-cat-text {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', sans-serif;
  font-size: 26rpx;
  color: #8e8b82;
}

/* ═══════════════════════════════════════════
   备案号
   ═══════════════════════════════════════════ */
.footer {
  background: #faf9f5;
  padding: 48rpx 0 40rpx;
  text-align: center;
  opacity: 0;
}

.icp {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 22rpx;
  font-weight: 400;
  color: #8e8b82;
}

/* ═══════════════════════════════════════════
   精选工具区域（首页默认视图）
   ═══════════════════════════════════════════ */
.featured-section {
  margin-bottom: 8rpx;
}

.featured-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.featured-card {
  flex: 0 0 48%;
  margin-bottom: 20rpx;
  background: #efe9de;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  position: relative;
  box-sizing: border-box;
}

.featured-card:active {
  background: #e8e0d2;
}

.featured-card-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.featured-card-name {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 30rpx;
  font-weight: 600;
  color: #141413;
  line-height: 1.35;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  min-width: 0;
}

.featured-card-diff {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', sans-serif;
  font-size: 20rpx;
  font-weight: 400;
  color: #8e8b82;
  line-height: 1.4;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.featured-card-tagline {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', sans-serif;
  font-size: 22rpx;
  font-weight: 400;
  color: #6c6a64;
  line-height: 1.4;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.featured-card-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: auto;
}

.featured-card-category {
  display: inline-block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', sans-serif;
  font-size: 20rpx;
  font-weight: 500;
  color: #cc785c;
  background: rgba(204, 120, 92, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

/* ── 详细模式：featured-card tagline 不截断 ── */
.fc-tagline-detail {
  overflow: visible;
  display: block;
  -webkit-line-clamp: unset;
}

/* ── 详细模式：featured-card tags + 难度行 ── */
.fc-meta-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 6rpx;
  margin-bottom: 4rpx;
}

.fc-tags-inline {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', sans-serif;
  font-size: 18rpx;
  font-weight: 400;
  color: #6c6a64;
  line-height: 1.4;
}

.fc-diff-label {
  display: inline-block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', sans-serif;
  font-size: 18rpx;
  font-weight: 400;
  color: #8e8b82;
  line-height: 1.4;
  margin-left: 12rpx;
}

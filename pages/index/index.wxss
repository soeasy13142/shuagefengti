/* 动画 */
@keyframes blobMove1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25% { transform: translate(60rpx, -40rpx) scale(1.1); }
  50% { transform: translate(-30rpx, 50rpx) scale(0.95); }
  75% { transform: translate(40rpx, 20rpx) scale(1.05); }
}

@keyframes blobMove2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(-50rpx, 60rpx) scale(1.15); }
  66% { transform: translate(40rpx, -30rpx) scale(0.9); }
}

@keyframes blobMove3 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(70rpx, 40rpx) scale(1.08); }
}

@keyframes blobMove4 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  40% { transform: translate(-40rpx, -50rpx) scale(1.12); }
  80% { transform: translate(30rpx, 30rpx) scale(0.92); }
}

@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(60rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.anim-in {
  animation: fadeSlideIn 0.6s ease-out both;
}

.anim-up {
  animation: fadeSlideUp 0.6s ease-out 0.2s both;
}

.anim-up-delay {
  animation: fadeSlideUp 0.6s ease-out 0.35s both;
}

.anim-up-delay2 {
  animation: fadeSlideUp 0.6s ease-out 0.5s both;
}

/* 页面 */
.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: #0f0f1a;
  padding-bottom: 60rpx;
}

/* 动态背景 */
.bg {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 0;
}

.bg-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
}

.bg-blob-1 {
  width: 500rpx;
  height: 500rpx;
  background: rgba(102, 126, 234, 0.35);
  top: -100rpx;
  left: -80rpx;
  animation: blobMove1 12s ease-in-out infinite;
}

.bg-blob-2 {
  width: 400rpx;
  height: 400rpx;
  background: rgba(240, 147, 251, 0.3);
  top: 200rpx;
  right: -60rpx;
  animation: blobMove2 15s ease-in-out infinite;
}

.bg-blob-3 {
  width: 350rpx;
  height: 350rpx;
  background: rgba(79, 172, 254, 0.25);
  bottom: 300rpx;
  left: 50rpx;
  animation: blobMove3 10s ease-in-out infinite;
}

.bg-blob-4 {
  width: 300rpx;
  height: 300rpx;
  background: rgba(245, 87, 108, 0.2);
  bottom: 100rpx;
  right: 30rpx;
  animation: blobMove4 18s ease-in-out infinite;
}

/* 内容层 */
.content {
  position: relative;
  z-index: 1;
  padding: 0 32rpx;
}

/* 标题区 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 48rpx;
  opacity: 0;
}

.logo-ring {
  width: 112rpx;
  height: 112rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  backdrop-filter: blur(20px);
}

.logo-emoji {
  font-size: 56rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #fff, rgba(255, 255, 255, 0.7));
  -webkit-background-clip: text;
  color: transparent;
  letter-spacing: 8rpx;
  margin-bottom: 12rpx;
}

.tagline {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 4rpx;
}

/* 主功能卡片 */
.hero-card {
  position: relative;
  border-radius: 28rpx;
  margin-bottom: 28rpx;
  overflow: hidden;
  opacity: 0;
}

.hero-card:active {
  transform: scale(0.95);
}

.hero-hover {
  transform: scale(0.96);
}

.hero-hover .hero-glow {
  filter: brightness(1.3);
}

.hero-hover .hero-inner {
  background: rgba(20, 20, 40, 0.95);
}

/* 点击动画：只保留光晕脉冲，不动 transform */
.hero-tapped .hero-glow {
  animation: glowPulse 0.35s ease-out;
}

@keyframes glowPulse {
  0%   { filter: brightness(1); }
  30%  { filter: brightness(2); }
  100% { filter: brightness(1); }
}

.hero-glow {
  position: absolute;
  top: -2rpx; left: -2rpx; right: -2rpx; bottom: -2rpx;
  background: linear-gradient(135deg, #667eea, #f093fb, #4facfe, #f5576c);
  border-radius: 30rpx;
  z-index: 0;
}

.hero-inner {
  position: relative;
  z-index: 1;
  background: rgba(15, 15, 30, 0.92);
  backdrop-filter: blur(24px);
  border-radius: 28rpx;
  padding: 44rpx 36rpx;
  display: flex;
  align-items: center;
}

.hero-icon-box {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}

.hero-icon {
  font-size: 48rpx;
}

.hero-text {
  flex: 1;
}

.hero-name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.hero-desc {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 1rpx;
}

.hero-arrow {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 功能卡片组 */
.card-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 28rpx;
  opacity: 0;
}

.glass-card {
  flex: 1;
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  min-height: 180rpx;
}

.glass-card:active {
  transform: scale(0.96);
}

.glass-disabled {
  opacity: 0.5;
}

.glass-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  opacity: 0.15;
}

.glass-content {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(16px);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 180rpx;
  justify-content: center;
}

.glass-icon {
  font-size: 48rpx;
  margin-bottom: 14rpx;
}

.glass-name {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.glass-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  font-size: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.5);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

/* 底部入口 */
.bottom-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  opacity: 0;
}

.bottom-card {
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(16px);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.bottom-card:active {
  transform: scale(0.97);
  background: rgba(255, 255, 255, 0.1);
}

.bottom-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.bottom-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
}

.bottom-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.3);
  font-weight: 300;
}

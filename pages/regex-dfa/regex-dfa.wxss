/* ── 页面基础 ── */
.page {
  min-height: 100vh;
  background: #faf9f5;
  padding: 20rpx 24rpx 60rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Georgia', serif;
  color: #141413;
}

.band-label {
  display: block;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 32rpx;
  font-weight: 400;
  letter-spacing: -3rpx;
  color: #141413;
  margin-bottom: 8rpx;
}

.band-subtitle {
  display: block;
  font-size: 24rpx;
  color: #6c6a64;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.section-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #6c6a64;
  margin-bottom: 12rpx;
  margin-top: 20rpx;
  letter-spacing: 1rpx;
}

.error-text {
  display: block;
  margin-top: 12rpx;
  color: #c0392b;
  font-size: 24rpx;
}

/* ── 输入区 ── */
.input-band {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.sample-row {
  margin-bottom: 16rpx;
}

.sample-picker {
  background: #faf9f5;
  border-radius: 12rpx;
  padding: 14rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: #141413;
}

.sample-picker-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-arrow {
  color: #6c6a64;
  margin-left: 8rpx;
}

.input-row {
  margin-bottom: 16rpx;
}

.regex-input {
  background: #faf9f5;
  border-radius: 12rpx;
  padding: 14rpx 20rpx;
  font-size: 28rpx;
  font-family: 'Menlo', 'Courier New', monospace;
  color: #141413;
  width: 100%;
  box-sizing: border-box;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-primary {
  flex: 1;
  background: #cc785c;
  color: #faf9f5;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  text-align: center;
  border: none;
  line-height: 1.4;
}

.btn-hover {
  opacity: 0.85;
}

.btn-secondary {
  flex: 1;
  background: transparent;
  color: #6c6a64;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  text-align: center;
  border: 2rpx solid #d5cfc5;
  line-height: 1.4;
}

.btn-sm {
  flex: none;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  min-width: 120rpx;
}

/* ── Tab 栏 ── */
.tab-bar {
  display: flex;
  border-bottom: 2rpx solid #d5cfc5;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #6c6a64;
}

.tab-active {
  color: #cc785c;
  border-bottom: 4rpx solid #cc785c;
  font-weight: 600;
}

/* ── 结果卡片 ── */
.result-card {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.step-content {
  margin-top: 8rpx;
}

/* ── 状态节点 ── */
.states-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
  padding: 20rpx 0;
}

.state-node-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.state-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #faf9f5;
  border: 3rpx solid #8a8580;
  display: flex;
  align-items: center;
  justify-content: center;
}

.state-accept {
  border: 3rpx solid #8a8580;
  box-shadow: 0 0 0 8rpx #faf9f5, 0 0 0 11rpx #8a8580;
}

.state-start {
  border-color: #cc785c;
  box-shadow: 0 0 0 8rpx #faf9f5, 0 0 0 11rpx #cc785c;
}

.state-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #141413;
  font-family: 'Menlo', 'Courier New', monospace;
}

.state-tag {
  font-size: 20rpx;
  color: #6c6a64;
}

/* ── 转移表 ── */
.transition-table {
  background: #faf9f5;
  border-radius: 12rpx;
  overflow: hidden;
}

.tt-row {
  display: flex;
  padding: 10rpx 16rpx;
  border-bottom: 1rpx solid #d5cfc5;
  align-items: center;
}

.tt-header {
  background: #d5cfc5;
  font-weight: 600;
}

.tt-cell {
  font-size: 22rpx;
  font-family: 'Menlo', 'Courier New', monospace;
}

.tt-cell-from {
  width: 50rpx;
  text-align: center;
}

.tt-cell-arrow {
  width: 40rpx;
  text-align: center;
  color: #6c6a64;
}

.tt-cell-input {
  width: 80rpx;
  text-align: center;
  font-weight: 600;
}

.tt-cell-arrow2 {
  width: 40rpx;
  text-align: center;
  color: #6c6a64;
}

.tt-cell-to {
  width: 50rpx;
  text-align: center;
}

.eps-input {
  color: #8a8580;
  font-style: italic;
}

.tt-cell-empty {
  padding: 20rpx;
  text-align: center;
  color: #6c6a64;
  font-size: 24rpx;
}

/* ── 子集构造步骤 ── */
.subset-steps {
  margin-top: 8rpx;
}

.subset-step {
  background: #faf9f5;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.subset-step-header {
  margin-bottom: 8rpx;
}

.subset-step-num {
  font-size: 24rpx;
  font-weight: 600;
  color: #cc785c;
}

.subset-step-body {
  padding-left: 8rpx;
}

.subset-line {
  display: block;
  font-size: 22rpx;
  font-family: 'Menlo', 'Courier New', monospace;
  color: #141413;
  line-height: 1.8;
}

/* ── DFA 状态汇总 ── */
.dfa-states-summary {
  margin-top: 16rpx;
}

.dfa-state-summary {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}

.dfa-state-nfas {
  font-size: 22rpx;
  font-family: 'Menlo', 'Courier New', monospace;
  color: #6c6a64;
}

/* ── DFA 转移表网格 ── */
.tt-scroll {
  width: 100%;
  margin-bottom: 12rpx;
}

.tt-grid {
  display: table;
  border-collapse: collapse;
  font-size: 22rpx;
}

.tt-grid-row {
  display: table-row;
}

.tt-grid-header .tt-grid-cell {
  background: #d5cfc5;
  font-weight: 600;
}

.tt-grid-start {
  background: #f0e6d8;
}

.tt-grid-highlight {
  background: #e8dcd0;
}

.tt-grid-cell {
  display: table-cell;
  padding: 8rpx 12rpx;
  border: 1rpx solid #d5cfc5;
  text-align: center;
  font-family: 'Menlo', 'Courier New', monospace;
  min-width: 60rpx;
}

.tt-grid-state {
  font-weight: 600;
  min-width: 100rpx;
}

.tt-grid-input {
  min-width: 60rpx;
}

.tt-grid-accept {
  min-width: 60rpx;
}

.tt-grid-yes {
  color: #27ae60;
  font-weight: 600;
}

.tt-grid-none {
  color: #d5cfc5;
}

/* ── 模拟运行 ── */
.simulation-band {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.sim-input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.sim-input {
  flex: 1;
  background: #faf9f5;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  font-family: 'Menlo', 'Courier New', monospace;
  color: #141413;
}

.sim-result {
  margin-top: 16rpx;
}

.sim-result-text {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.sim-accepted {
  color: #27ae60;
}

.sim-rejected {
  color: #c0392b;
}

.sim-path {
  font-family: 'Menlo', 'Courier New', monospace;
  font-size: 22rpx;
  color: #141413;
  line-height: 2;
}

.sim-step {
  white-space: nowrap;
}

.sim-char {
  color: #6c6a64;
}

.sim-dead {
  color: #c0392b;
  font-weight: 600;
}

/* ── 状态图 ── */
.diagram-canvas {
  position: relative;
  width: 100%;
  height: 350rpx;
  overflow: hidden;
  background: #faf9f5;
  border-radius: 12rpx;
  margin: 12rpx 0 16rpx;
  border: 1rpx solid #d5cfc5;
}

.diagram-state {
  position: absolute;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #faf9f5;
  border: 3rpx solid #8a8580;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, -50%);
  z-index: 2;
}

.diagram-state.state-accept {
  border: 3rpx solid #8a8580;
  box-shadow: 0 0 0 8rpx #faf9f5, 0 0 0 11rpx #8a8580;
}

.diagram-state.state-start {
  border-color: #cc785c;
  box-shadow: 0 0 0 8rpx #faf9f5, 0 0 0 11rpx #cc785c;
}

.diagram-state.state-highlighted {
  background: #cc785c;
  border-color: #cc785c;
}

.diagram-state.state-highlighted .state-label {
  color: #faf9f5;
}

/* Arrow group (wrapper for line + head + label) */
.arrow-group {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
}

/* Arrow line */
.arrow-line {
  position: absolute;
  height: 3rpx;
  background: #8a8580;
  transform-origin: 0 50%;
  z-index: 1;
  top: 0;
  left: 0;
}

.arrow-line.arrow-highlight {
  background: #cc785c;
  height: 4rpx;
}

/* Arrowhead */
.arrow-head {
  position: absolute;
  width: 0;
  height: 0;
  border-left: 12rpx solid #8a8580;
  border-top: 6rpx solid transparent;
  border-bottom: 6rpx solid transparent;
  transform-origin: 0 50%;
  z-index: 1;
  top: 0;
  left: 0;
}

.arrow-head.arrow-highlight {
  border-left-color: #cc785c;
}

/* ε 虚线 */
.eps-arrow.arrow-line {
  border-top: 3rpx dashed #8a8580;
  background: transparent !important;
  height: 0 !important;
}

.eps-arrow.arrow-line.arrow-highlight {
  border-top-color: #cc785c;
}

.eps-arrow.arrow-head {
  border-left: 12rpx dashed #8a8580;
  background: transparent;
  height: 0;
  border-top: 6rpx solid transparent;
  border-bottom: 6rpx solid transparent;
}

.eps-arrow.arrow-head.arrow-highlight {
  border-left-color: #cc785c;
}

/* Arrow label */
.arrow-label {
  position: absolute;
  font-size: 20rpx;
  font-family: 'Menlo', 'Courier New', monospace;
  color: #6c6a64;
  z-index: 3;
  background: #faf9f5;
  padding: 2rpx 6rpx;
  border-radius: 6rpx;
  transform: translate(-50%, -50%);
  white-space: nowrap;
  line-height: 1.4;
  top: 0;
  left: 0;
}

.arrow-label.eps-label {
  color: #8a8580;
  font-style: italic;
}

/* ── 步进导航 ── */
.step-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin: 16rpx 0;
  padding-top: 12rpx;
}

.step-btn {
  background: #faf9f5;
  border: 2rpx solid #d5cfc5;
  border-radius: 12rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #141413;
  min-width: 130rpx;
  text-align: center;
  line-height: 1.4;
}

.step-btn:active {
  opacity: 0.7;
}

.step-indicator {
  font-size: 22rpx;
  color: #6c6a64;
  font-family: 'Menlo', 'Courier New', monospace;
  min-width: 140rpx;
  text-align: center;
}

/* ── 子集构造高亮 ── */
.subset-step-highlight {
  border-left: 6rpx solid #cc785c;
}

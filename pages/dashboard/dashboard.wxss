/* ═══════════════════════════════════════════
   Claude Design — 学习驾驶舱
   暖奶油画布 · 珊瑚主色 · 奶油卡片
   ═══════════════════════════════════════════ */

.page {
  min-height: 100vh;
  background: #faf9f5;
  padding: 0 32rpx 60rpx;
}

/* ── 空状态 ── */
.empty-hint {
  padding: 40rpx 32rpx;
  border-radius: 24rpx;
  margin-top: 40rpx;
  background: #efe9de;
}

.empty-title {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 32rpx;
  font-weight: 500;
  color: #141413;
}

.empty-desc {
  display: block;
  margin-top: 14rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6c6a64;
}

.empty-button {
  margin-top: 28rpx;
  display: inline-block;
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  background: #cc785c;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  font-weight: 500;
  color: #ffffff;
}

.empty-button:active {
  background: #a9583e;
}

/* ── 区域标签 ── */
.section-label {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  font-weight: 500;
  color: #6c6a64;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin: 32rpx 0 20rpx 4rpx;
}

/* ── 总览指标 2x2 ── */
.overview-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.metric-card {
  flex: 0 0 48%;
  margin-bottom: 16rpx;
  background: #efe9de;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
}

.metric-value {
  display: block;
  font-family: Georgia, 'Times New Roman', 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
  font-size: 48rpx;
  font-weight: 400;
  color: #141413;
  line-height: 1.1;
  letter-spacing: -1rpx;
}

.metric-label {
  display: block;
  margin-top: 8rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 22rpx;
  color: #6c6a64;
}

/* ── 通用卡片 ── */
.section-card {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-top: 16rpx;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 30rpx;
  font-weight: 500;
  color: #141413;
}

.section-tag {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: #f5f0e8;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 20rpx;
  font-weight: 500;
  color: #6c6a64;
}

/* ── 题型雷达 ── */
.type-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.type-info {
  width: 100rpx;
  flex-shrink: 0;
}

.type-name {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 26rpx;
  font-weight: 500;
  color: #141413;
}

.type-meta {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 20rpx;
  color: #8e8b82;
  margin-top: 2rpx;
}

.type-bar-bg {
  flex: 1;
  height: 16rpx;
  background: #f5f0e8;
  border-radius: 999rpx;
  overflow: hidden;
}

.type-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #cc785c, #e8a55a);
  min-width: 0;
  transition: width 0.4s ease;
}

.type-accuracy {
  width: 80rpx;
  text-align: right;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  font-weight: 500;
  color: #cc785c;
  flex-shrink: 0;
}

/* ── 7天趋势 ── */
.trend-chart {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 240rpx;
}

.trend-item {
  width: 13%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.trend-bar-wrap {
  height: 170rpx;
  display: flex;
  align-items: flex-end;
}

.trend-bar {
  width: 34rpx;
  min-height: 8rpx;
  border-radius: 999rpx 999rpx 8rpx 8rpx;
  background: linear-gradient(180deg, #cc785c, #a9583e);
}

.trend-count {
  margin-top: 8rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 22rpx;
  font-weight: 500;
  color: #141413;
}

.trend-date {
  margin-top: 4rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 18rpx;
  color: #8e8b82;
}

/* ── 错题掌握 ── */
.wrong-summary {
  display: flex;
  gap: 16rpx;
}

.wrong-item {
  flex: 1;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f5f0e8;
}

.wrong-value {
  display: block;
  font-family: Georgia, 'Times New Roman', 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
  font-size: 44rpx;
  font-weight: 400;
  color: #c64545;
  line-height: 1.1;
}

.wrong-value.mastered {
  color: #5db872;
}

.wrong-label {
  display: block;
  margin-top: 8rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 22rpx;
  color: #6c6a64;
}

.action-button {
  margin-top: 24rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 16rpx;
  background: #cc785c;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 26rpx;
  font-weight: 500;
  color: #ffffff;
}

.action-button:active {
  background: #a9583e;
}

/* ── 智能建议 ── */
.suggestion-card {
  border: 1rpx solid #e6dfd8;
}

.suggestion-item {
  padding: 24rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  background: #f5f0e8;
}

.suggestion-item:last-child {
  margin-bottom: 0;
}

.suggestion-title {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  font-weight: 500;
  color: #141413;
}

.suggestion-content {
  display: block;
  margin-top: 10rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6c6a64;
}

.suggestion-action {
  display: block;
  margin-top: 14rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  font-weight: 500;
  color: #cc785c;
}

/* 建议级别色条 */
.suggestion-warning {
  border-left: 6rpx solid #d4a017;
}

.suggestion-info {
  border-left: 6rpx solid #6c6a64;
}

.suggestion-success {
  border-left: 6rpx solid #5db872;
}

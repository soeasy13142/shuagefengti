/* ======================== 页面基础 ======================== */
.tcp-page {
  min-height: 100vh;
  background: #faf9f5;
  padding: 20rpx 24rpx 40rpx;
}

/* ======================== 模式选择 ======================== */
.mode-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.mode-tab {
  display: inline-block;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #efe9de;
  color: #6c6a64;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.25s ease;
  flex-shrink: 0;
}

.mode-active {
  background: #cc785c;
  color: #fff;
}

/* ======================== 场景说明 ======================== */
.scenario-hint {
  padding: 16rpx 24rpx;
  background: #efe9de;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.scenario-hint-text {
  font-size: 24rpx;
  color: #6c6a64;
  line-height: 1.5;
}

/* ======================== 序列图 ======================== */
.diagram-card {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
}

.diagram-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.diagram-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.col-left {
  width: 15%;
}

.col-mid {
  width: 70%;
}

.col-right {
  width: 15%;
}

.endpoint-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #141413;
  font-family: Georgia, 'Times New Roman', serif;
}

/* ======================== 箭头区域 ======================== */
.arrows-area {
  min-height: 200rpx;
  position: relative;
}

.arrow-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.v-line-seg {
  width: 4rpx;
  height: 60rpx;
  background: #b8b4ac;
}

.arrow {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  width: 100%;
}

.arrow-line {
  position: absolute;
  top: 50%;
  left: 8rpx;
  right: 8rpx;
  height: 3rpx;
  transform: translateY(-50%);
}

/* 箭头类型颜色 */
.arrow-type-syn .arrow-line { background: #cc785c; }
.arrow-type-syn-ack .arrow-line { background: linear-gradient(90deg, #cc785c, #60a5fa); }
.arrow-type-ack .arrow-line { background: #8e8b82; }
.arrow-type-fin .arrow-line { background: #f97316; }
.arrow-type-data .arrow-line { background: #34d399; }

/* 箭头头部 */
.arrow-head {
  position: absolute;
  top: 50%;
  width: 0;
  height: 0;
  transform: translateY(-50%);
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
}

.arrow-head-left-to-right {
  right: 4rpx;
  border-left: 16rpx solid #8e8b82;
  border-right: none;
}

.arrow-head-right-to-left {
  left: 4rpx;
  border-right: 16rpx solid #8e8b82;
  border-left: none;
}

.arrow-type-syn .arrow-head-left-to-right { border-left-color: #cc785c; }
.arrow-type-syn .arrow-head-right-to-left { border-right-color: #cc785c; }
.arrow-type-syn-ack .arrow-head-left-to-right { border-left-color: #60a5fa; }
.arrow-type-syn-ack .arrow-head-right-to-left { border-right-color: #cc785c; }
.arrow-type-fin .arrow-head-left-to-right { border-left-color: #f97316; }
.arrow-type-fin .arrow-head-right-to-left { border-right-color: #f97316; }
.arrow-type-data .arrow-head-left-to-right { border-left-color: #34d399; }
.arrow-type-data .arrow-head-right-to-left { border-right-color: #34d399; }

.arrow-label {
  position: relative;
  z-index: 1;
  font-size: 22rpx;
  font-family: 'SF Mono', 'Menlo', 'Courier New', monospace;
  color: #141413;
  background: #efe9de;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

/* 当前/过去箭头 */
.arrow-current {
  animation: arrowFadeIn 0.35s ease-out;
}

.arrow-past {
  opacity: 0.5;
}

@keyframes arrowFadeIn {
  from {
    opacity: 0;
    transform: translateX(-16rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* 空状态 */
.arrows-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 200rpx;
}

.arrows-empty-text {
  font-size: 28rpx;
  color: #8e8b82;
}

/* ======================== 状态标签 ======================== */
.state-bar {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #e6dfd8;
}

.state-badge {
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  transition: background 0.3s ease;
}

.state-badge-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  font-family: 'SF Mono', 'Menlo', 'Courier New', monospace;
}

/* ======================== 步骤详情 ======================== */
.detail-card {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.detail-step-num {
  font-size: 22rpx;
  color: #8e8b82;
  padding: 6rpx 16rpx;
  background: #faf9f5;
  border-radius: 999rpx;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #141413;
  font-family: Georgia, 'Times New Roman', serif;
}

/* 标志位 */
.flags-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.flag-badge {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  font-family: 'SF Mono', 'Menlo', 'Courier New', monospace;
  background: #faf9f5;
  color: #b8b4ac;
  border: 2rpx solid #e6dfd8;
  transition: all 0.25s ease;
}

.flag-active {
  background: #cc785c;
  color: #fff;
  border-color: #cc785c;
}

/* seq/ack */
.seq-area {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.seq-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.seq-label {
  font-size: 22rpx;
  color: #8e8b82;
  font-family: 'SF Mono', 'Menlo', 'Courier New', monospace;
  text-transform: uppercase;
}

.seq-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #141413;
  font-family: 'SF Mono', 'Menlo', 'Courier New', monospace;
}

/* 状态变化 */
.state-change-area {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.state-change {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sc-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #6c6a64;
  width: 100rpx;
}

.sc-from {
  font-size: 24rpx;
  color: #8e8b82;
  font-family: 'SF Mono', 'Menlo', 'Courier New', monospace;
  padding: 4rpx 12rpx;
  background: #faf9f5;
  border-radius: 8rpx;
}

.sc-arrow {
  font-size: 24rpx;
  color: #cc785c;
}

.sc-to {
  font-size: 24rpx;
  font-weight: 600;
  font-family: 'SF Mono', 'Menlo', 'Courier New', monospace;
  padding: 4rpx 12rpx;
  background: #cc785c;
  color: #fff;
  border-radius: 8rpx;
}

/* 解释 */
.explanation {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: #3d3d3a;
  margin-bottom: 16rpx;
}

/* 面试提示 */
.exam-tip {
  display: flex;
  gap: 12rpx;
  padding: 20rpx;
  background: #faf9f5;
  border-radius: 16rpx;
  border-left: 6rpx solid #cc785c;
}

.exam-tip-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.exam-tip-text {
  font-size: 24rpx;
  line-height: 1.6;
  color: #6c6a64;
}

/* ======================== 控制栏 ======================== */
.control-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #efe9de;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.ctrl-btn {
  min-width: 72rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background: #faf9f5;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  transition: background 0.2s ease;
}

.ctrl-btn:active {
  background: #e8e0d2;
}

.ctrl-play {
  background: #cc785c;
  min-width: 88rpx;
  height: 68rpx;
  padding: 0 28rpx;
}

.ctrl-play:active {
  background: #a9583e;
}

.ctrl-play .ctrl-icon,
.ctrl-play .ctrl-text {
  color: #fff;
}

.ctrl-text {
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.ctrl-icon {
  font-size: 24rpx;
  color: #3d3d3a;
  white-space: nowrap;
}

.speed-area {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: 8rpx;
}

.speed-label {
  font-size: 22rpx;
  color: #8e8b82;
  flex-shrink: 0;
}

.speed-slider {
  flex: 1;
  margin: 0;
}

/* ======================== 知识点 ======================== */
.knowledge-section {
  background: #efe9de;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
}

.knowledge-toggle {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 28rpx;
}

.kt-icon {
  font-size: 28rpx;
}

.kt-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #141413;
}

.kt-arrow {
  font-size: 22rpx;
  color: #8e8b82;
}

.knowledge-list {
  padding: 0 28rpx 28rpx;
}

.knowledge-card {
  padding: 20rpx;
  background: #faf9f5;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.knowledge-card:last-child {
  margin-bottom: 0;
}

.kc-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #141413;
  margin-bottom: 12rpx;
}

.kc-content {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6c6a64;
}

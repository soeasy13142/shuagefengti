<view class="page">
  <view class="content">
    <!-- Mode Tabs -->
    <view class="mode-tabs">
      <view
        class="mode-tab {{currentMode === item.key ? 'mode-active' : ''}}"
        wx:for="{{modes}}"
        wx:key="key"
        data-mode="{{item.key}}"
        bindtap="onModeChange"
      >
        <text>{{item.name}}</text>
      </view>
    </view>

    <view class="beta-banner">
      <text class="beta-tag">测试版</text>
      <text class="beta-text">本功能仍在测试中，操作可能存在显示异常，如遇问题请刷新或切换模式重试</text>
    </view>

    <!-- BST Mode -->
    <block wx:if="{{currentMode === 'bst'}}">
      <view class="viz-area">
        <canvas canvas-id="vizCanvas" class="viz-canvas" />
        <view class="canvas-touch"
          bindtouchstart="onCanvasTouchStart"
          bindtouchmove="onCanvasTouchMove"
          bindtouchend="onCanvasTouchEnd"
        ></view>
      </view>
      <view class="input-area">
        <text class="input-title">BST 操作</text>
        <view class="input-row">
          <input class="input-field" placeholder="输入数字 1-99" placeholder-class="input-ph" value="{{bstInput}}" bindinput="onBstInput" bindconfirm="onBstInsert" type="number" />
          <view class="input-btn" bindtap="onBstInsert"><text class="btn-text">插入</text></view>
          <view class="input-btn input-btn-secondary" bindtap="onBstSearch"><text class="btn-text">查找</text></view>
          <view class="input-btn input-btn-danger" bindtap="onBstDelete"><text class="btn-text">删除</text></view>
        </view>
        <view class="input-row" style="margin-top: 12rpx;">
          <view class="input-btn" bindtap="onBstRandom"><text class="btn-text">🎲 随机</text></view>
          <view class="input-btn input-btn-secondary" bindtap="onBstRandomBatch"><text class="btn-text">批量生成</text></view>
        </view>
        <view class="quick-row">
          <text class="quick-label">遍历：</text>
          <view class="quick-btn" data-order="pre" bindtap="onBstTraverse"><text>前序</text></view>
          <view class="quick-btn" data-order="in" bindtap="onBstTraverse"><text>中序</text></view>
          <view class="quick-btn" data-order="post" bindtap="onBstTraverse"><text>后序</text></view>
          <view class="quick-btn" data-order="level" bindtap="onBstTraverse"><text>层序</text></view>
        </view>
      </view>
    </block>

    <!-- Stack & Queue Mode -->
    <block wx:if="{{currentMode === 'stack-queue'}}">
      <view class="sq-tabs">
        <view class="sq-tab {{sqType === 'stack' ? 'sq-active' : ''}}" data-type="stack" bindtap="onSqTypeChange"><text>栈 Stack</text></view>
        <view class="sq-tab {{sqType === 'queue' ? 'sq-active' : ''}}" data-type="queue" bindtap="onSqTypeChange"><text>队列 Queue</text></view>
      </view>
      <view class="viz-area sq-viz">
        <!-- Stack: vertical -->
        <view wx:if="{{sqType === 'stack'}}" class="stack-container">
          <view class="sq-label">栈顶 ↑</view>
          <view class="stack-items">
            <view class="sq-item {{item.state}}" wx:for="{{sqElements}}" wx:key="value" style="transform: translateY({{(sqElements.length - 1 - index) * -70}}rpx);">
              <text class="sq-value">{{item.value}}</text>
            </view>
            <view wx:if="{{sqElements.length === 0}}" class="sq-empty">空栈</view>
          </view>
        </view>
        <!-- Queue: horizontal -->
        <view wx:if="{{sqType === 'queue'}}" class="queue-container">
          <view class="queue-items">
            <view class="sq-item sq-item-h {{item.state}}" wx:for="{{sqElements}}" wx:key="value">
              <text class="sq-value">{{item.value}}</text>
              <text class="sq-role" wx:if="{{index === 0}}">队首</text>
              <text class="sq-role" wx:if="{{index === sqElements.length - 1 && sqElements.length > 1}}">队尾</text>
            </view>
            <view wx:if="{{sqElements.length === 0}}" class="sq-empty">空队列</view>
          </view>
          <view class="queue-arrow" wx:if="{{sqElements.length > 1}}">→ 入队方向</view>
        </view>
      </view>
      <view class="input-area">
        <text class="input-title">{{sqType === 'stack' ? '栈操作' : '队列操作'}}</text>
        <view class="input-row">
          <input class="input-field" placeholder="输入数字 1-99" placeholder-class="input-ph" value="{{sqInput}}" bindinput="onSqInput" type="number" />
          <view wx:if="{{sqType === 'stack'}}" class="input-btn" bindtap="onSqPush"><text class="btn-text">Push</text></view>
          <view wx:if="{{sqType === 'stack'}}" class="input-btn input-btn-secondary" bindtap="onSqPop"><text class="btn-text">Pop</text></view>
          <view wx:if="{{sqType === 'queue'}}" class="input-btn" bindtap="onSqEnqueue"><text class="btn-text">Enqueue</text></view>
          <view wx:if="{{sqType === 'queue'}}" class="input-btn input-btn-secondary" bindtap="onSqDequeue"><text class="btn-text">Dequeue</text></view>
        </view>
        <view class="input-row" style="margin-top: 12rpx;">
          <view class="input-btn" bindtap="onSqRandom"><text class="btn-text">🎲 随机入{{sqType === 'stack' ? '栈' : '队'}}</text></view>
          <view class="input-btn input-btn-secondary" bindtap="onSqRandomBatch"><text class="btn-text">批量生成</text></view>
        </view>
      </view>
    </block>

    <!-- Hash Table Mode -->
    <block wx:if="{{currentMode === 'hash'}}">
      <view class="viz-area hash-viz">
        <view class="hash-buckets">
          <view class="hash-bucket" wx:for="{{hashBuckets}}" wx:key="index">
            <view class="bucket-index">[{{index}}]</view>
            <view class="bucket-chain">
              <view class="hash-entry" wx:for="{{item.entries}}" wx:for-item="entry" wx:key="key">
                <view class="entry-node">
                  <text class="entry-key">{{entry.key}}</text>
                </view>
                <text class="chain-arrow" wx:if="{{index < item.entries.length - 1}}">→</text>
              </view>
              <text class="chain-null" wx:if="{{item.entries.length === 0}}">null</text>
            </view>
          </view>
        </view>
      </view>
      <view class="input-area">
        <text class="input-title">哈希表操作</text>
        <text class="input-hint">桶数 {{hashTableSize}}，链地址法解决冲突</text>
        <view class="input-row">
          <input class="input-field" placeholder="输入 key（如 apple）" placeholder-class="input-ph" value="{{hashInput}}" bindinput="onHashInput" />
          <view class="input-btn" bindtap="onHashInsert"><text class="btn-text">插入</text></view>
          <view class="input-btn input-btn-secondary" bindtap="onHashSearch"><text class="btn-text">查找</text></view>
        </view>
        <view class="input-row" style="margin-top: 12rpx;">
          <view class="input-btn" bindtap="onHashRandom"><text class="btn-text">🎲 随机 key</text></view>
          <view class="input-btn input-btn-secondary" bindtap="onHashRandomBatch"><text class="btn-text">批量插入</text></view>
        </view>
      </view>
    </block>

    <!-- Graph Mode -->
    <block wx:if="{{currentMode === 'graph'}}">
      <view class="viz-area">
        <canvas canvas-id="vizCanvas" class="viz-canvas" />
        <view class="canvas-touch"
          bindtouchstart="onCanvasTouchStart"
          bindtouchmove="onCanvasTouchMove"
          bindtouchend="onCanvasTouchEnd"
        ></view>
      </view>
      <view class="input-area">
        <text class="input-title">图搜索</text>
        <view class="quick-row" style="margin-bottom: 20rpx;">
          <text class="quick-label">图类型：</text>
          <view class="quick-btn {{graphType === 'simple' ? 'quick-active' : ''}}" data-type="simple" bindtap="onGraphTypeChange"><text>简单图</text></view>
          <view class="quick-btn {{graphType === 'tree' ? 'quick-active' : ''}}" data-type="tree" bindtap="onGraphTypeChange"><text>树形图</text></view>
          <view class="quick-btn {{graphType === 'cycle' ? 'quick-active' : ''}}" data-type="cycle" bindtap="onGraphTypeChange"><text>带环图</text></view>
        </view>
        <view class="input-row">
          <view class="input-btn" bindtap="onGraphBfs"><text class="btn-text">BFS</text></view>
          <view class="input-btn input-btn-secondary" bindtap="onGraphDfs"><text class="btn-text">DFS</text></view>
        </view>
      </view>
    </block>

    <!-- Step Info -->
    <view class="step-info" wx:if="{{ready && steps.length > 0}}">
      <text class="step-desc">{{stepDesc}}</text>
      <view class="step-stats">
        <text class="stat">步骤 {{stepIndex + 1}}/{{totalSteps}}</text>
      </view>
    </view>

    <!-- Playback Controls -->
    <view class="controls" wx:if="{{ready && steps.length > 0}}">
      <view class="control-row">
        <view class="ctrl-btn" bindtap="onStepPrev"><text class="ctrl-icon">⏮</text></view>
        <view class="ctrl-btn ctrl-play {{playing && !paused ? 'ctrl-active' : ''}}" bindtap="{{playing && !paused ? 'onPause' : 'onPlay'}}">
          <text class="ctrl-icon">{{playing && !paused ? '⏸' : '▶'}}</text>
        </view>
        <view class="ctrl-btn" bindtap="onStepNext"><text class="ctrl-icon">⏭</text></view>
        <view class="ctrl-btn" bindtap="onReset"><text class="ctrl-icon">↺</text></view>
      </view>
      <view class="speed-row">
        <text class="speed-label">慢</text>
        <slider class="speed-slider" min="1" max="10" step="1" value="{{speed}}" activeColor="#cc785c" backgroundColor="#e6dfd8" block-size="20" bindchange="onSpeedChange" />
        <text class="speed-label">快</text>
      </view>
    </view>
  </view>
</view>

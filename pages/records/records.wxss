.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.mode-tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.tag-green { background: rgba(7, 193, 96, 0.1); color: #07c160; }
.tag-blue { background: rgba(24, 144, 255, 0.1); color: #1890ff; }

.record-stats {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.record-accuracy {
  font-size: 40rpx;
  font-weight: 800;
}

.text-green { color: #07c160; }
.text-red { color: #e64340; }

.record-detail, .record-time {
  font-size: 22rpx;
  color: #8e8e93;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 28rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8e8e93;
}

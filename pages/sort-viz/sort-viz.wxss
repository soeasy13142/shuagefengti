/* ═══════════════════════════════════════════
   Claude Design — 排序可视化
   暖奶油画布 · 珊瑚主色 · 奶油卡片
   ═══════════════════════════════════════════ */

.page {
  min-height: 100vh;
  background: #faf9f5;
  padding-bottom: 60rpx;
}

.content {
  padding: 0 32rpx;
}

/* ── 算法选择标签 ── */
.algo-tabs {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 0 24rpx;
}

.algo-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 26rpx;
  font-weight: 500;
  color: #6c6a64;
  background: #f5f0e8;
  transition: all 0.25s ease;
}

.tab-active {
  color: #141413;
  background: #efe9de;
}

/* ── 柱状图区域 ── */
.chart-area {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
}

.chart-container {
  position: relative;
  min-width: 100%;
  margin: 0 auto;
}

/* ── 柱子 ── */
.bar-wrapper {
  position: absolute;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  transition: left 0.35s cubic-bezier(0.34, 1, 0.64, 1);
}

.bar-value {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 20rpx;
  font-weight: 500;
  color: #3d3d3a;
  margin-bottom: 6rpx;
  white-space: nowrap;
  transition: color 0.2s ease;
}

.bar-fill {
  width: 100%;
  border-radius: 8rpx 8rpx 4rpx 4rpx;
  transition: height 0.4s ease-out, background 0.25s ease;
}

/* 柱子颜色状态 — 暖色调适配浅色背景 */
.bar-default .bar-fill {
  background: linear-gradient(180deg, #cc785c, #a9583e);
}

.bar-compare .bar-fill {
  background: linear-gradient(180deg, #5db8a6, #3d9e8c);
}

.bar-compare .bar-value {
  color: #3d9e8c;
}

.bar-swap .bar-fill {
  background: linear-gradient(180deg, #c64545, #a63535);
}

.bar-swap .bar-value {
  color: #c64545;
}

.bar-sorted .bar-fill {
  background: linear-gradient(180deg, #5db872, #3d9e56);
}

.bar-sorted .bar-value {
  color: #3d9e56;
}

.bar-pivot .bar-fill {
  background: linear-gradient(180deg, #e8a55a, #d49017);
}

.bar-pivot .bar-value {
  color: #d49017;
}

/* ── 步骤信息 ── */
.step-info {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}

.step-desc {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  color: #3d3d3a;
  line-height: 1.6;
  margin-bottom: 14rpx;
}

.step-stats {
  display: flex;
  gap: 28rpx;
}

.stat {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 22rpx;
  color: #6c6a64;
}

/* ── 播放控制 ── */
.controls {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}

.control-row {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.ctrl-btn {
  min-width: 72rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background: #f5f0e8;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
}

.ctrl-btn:active {
  background: #e8e0d2;
}

.ctrl-play {
  min-width: 88rpx;
  height: 68rpx;
  padding: 0 28rpx;
  background: #cc785c;
}

.ctrl-play:active {
  background: #a9583e;
}

.ctrl-active {
  background: #a9583e;
}

.ctrl-icon {
  font-size: 24rpx;
  color: #6c6a64;
  white-space: nowrap;
}

.ctrl-play .ctrl-icon,
.ctrl-play .ctrl-text {
  font-size: 24rpx;
  color: #ffffff;
}

.ctrl-text {
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.speed-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.speed-label {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 20rpx;
  color: #6c6a64;
  flex-shrink: 0;
}

.speed-slider {
  flex: 1;
}

/* ── 输入区域 ── */
.input-area {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 28rpx;
}

.input-title {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 30rpx;
  font-weight: 500;
  color: #141413;
  margin-bottom: 8rpx;
}

.input-hint {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 22rpx;
  color: #8e8b82;
  margin-bottom: 24rpx;
}

.input-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.input-field {
  flex: 1;
  height: 76rpx;
  background: #faf9f5;
  border: 1rpx solid #e6dfd8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 26rpx;
  color: #141413;
}

.input-placeholder {
  color: #8e8b82;
}

.input-btn {
  width: 120rpx;
  height: 76rpx;
  background: #cc785c;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.input-btn:active {
  background: #a9583e;
}

.input-btn-text {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 26rpx;
  font-weight: 500;
  color: #ffffff;
}

.quick-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.quick-label {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  color: #6c6a64;
}

.quick-btn {
  padding: 14rpx 28rpx;
  background: #f5f0e8;
  border-radius: 999rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 24rpx;
  color: #3d3d3a;
}

.quick-btn:active {
  background: #e8e0d2;
  color: #cc785c;
}

.preview-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 44rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.preview-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 36rpx;
  color: #1a1a2e;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.stat-label {
  color: #8e8e93;
}

.stat-value {
  color: #1a1a2e;
  font-weight: 600;
}

.highlight {
  color: #07c160;
  font-weight: 700;
}

.type-breakdown {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.type-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  font-size: 26rpx;
  color: #666;
}

.type-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
}

.dot-blue { background: #1890ff; }
.dot-purple { background: #722ed1; }
.dot-orange { background: #fa8c16; }
.dot-green { background: #07c160; }
.dot-gray { background: #8e8e93; }

.actions {
  display: flex;
  gap: 24rpx;
}

.actions button {
  flex: 1;
}

@keyframes selectPop {
  0% { transform: scale(1); }
  40% { transform: scale(1.03); }
  100% { transform: scale(1); }
}

@keyframes selectGlow {
  0% { box-shadow: 0 0 0 0 rgba(7, 193, 96, 0.35); }
  70% { box-shadow: 0 0 0 10rpx rgba(7, 193, 96, 0); }
  100% { box-shadow: 0 0 0 0 rgba(7, 193, 96, 0); }
}

.mode-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  backdrop-filter: blur(4px);
}

.mode-dialog {
  background: #fff;
  border-radius: 32rpx;
  padding: 56rpx 48rpx;
  width: 80%;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.mode-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 44rpx;
  color: #1a1a2e;
}

.mode-option {
  padding: 32rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.mode-option:active {
  background: #f8f9fa;
}

.mode-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.mode-desc {
  font-size: 24rpx;
  color: #8e8e93;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.question-num {
  font-size: 26rpx;
  color: #8e8e93;
  font-weight: 500;
}

.type-tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.tag-blue { background: rgba(24, 144, 255, 0.1); color: #1890ff; }
.tag-purple { background: rgba(114, 46, 209, 0.1); color: #722ed1; }
.tag-orange { background: rgba(250, 140, 22, 0.1); color: #fa8c16; }
.tag-green { background: rgba(7, 193, 96, 0.1); color: #07c160; }
.tag-gray { background: rgba(0, 0, 0, 0.04); color: #8e8e93; }

.stem-area {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.stem-text {
  font-size: 32rpx;
  line-height: 1.7;
  color: #1a1a2e;
  font-weight: 500;
}

.options-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.option-item {
  background: #fff;
  border: 2rpx solid #f0f0f0;
  border-radius: 20rpx;
  padding: 28rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s ease;
}

.option-item:active {
  transform: scale(0.97);
}

.option-selected {
  border-color: #07c160;
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.08), rgba(6, 214, 160, 0.06));
  box-shadow: 0 4rpx 20rpx rgba(7, 193, 96, 0.18);
  animation: selectPop 0.3s ease, selectGlow 0.6s ease;
}

.option-correct {
  border-color: #07c160;
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.1), rgba(6, 214, 160, 0.06));
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.15);
}

.option-wrong {
  border-color: #e64340;
  background: linear-gradient(135deg, rgba(230, 67, 64, 0.08), rgba(230, 67, 64, 0.04));
  box-shadow: 0 4rpx 16rpx rgba(230, 67, 64, 0.12);
}

.option-radio {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #d8d8d8;
  border-radius: 50%;
  flex-shrink: 0;
  position: relative;
}

.radio-selected {
  border-color: #07c160;
  background: linear-gradient(135deg, #07c160, #06d6a0);
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.35);
}

.radio-selected::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.option-checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #d8d8d8;
  border-radius: 12rpx;
  flex-shrink: 0;
  position: relative;
}

.checkbox-selected {
  border-color: #07c160;
  background: linear-gradient(135deg, #07c160, #06d6a0);
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.35);
}

.checkbox-selected::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.option-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
}

.judge-area {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.judge-btn {
  flex: 1;
  background: #fff;
  border: 2rpx solid #f0f0f0;
  border-radius: 20rpx;
  padding: 44rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.judge-btn:active {
  transform: scale(0.96);
}

.judge-selected {
  border-color: #07c160;
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.08), rgba(6, 214, 160, 0.04));
  color: #07c160;
  box-shadow: 0 4rpx 20rpx rgba(7, 193, 96, 0.18);
  animation: selectPop 0.3s ease;
}

.fill-area { margin-bottom: 24rpx; }

.fill-input {
  background: #fff;
  border: 2rpx solid #f0f0f0;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.essay-area { margin-bottom: 24rpx; }

.essay-input {
  background: #fff;
  border: 2rpx solid #f0f0f0;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 28rpx;
  width: 100%;
  min-height: 200rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.explanation-area {
  background: rgba(250, 140, 22, 0.06);
  border: 2rpx solid rgba(250, 140, 22, 0.15);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.explanation-label {
  display: block;
  font-size: 22rpx;
  color: #fa8c16;
  font-weight: 700;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.explanation-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

.correct-answer-hint {
  background: rgba(7, 193, 96, 0.06);
  border: 2rpx solid rgba(7, 193, 96, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  gap: 12rpx;
}

.hint-label {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.hint-value {
  font-size: 26rpx;
  color: #07c160;
  font-weight: 600;
}

.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.btn-nav {
  flex: 1;
  background: #fff;
  color: #333;
  border: 2rpx solid #e8e8e8;
  border-radius: 14rpx;
  padding: 22rpx 0;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-nav[disabled] { opacity: 0.35; }

.btn-submit {
  flex: 1;
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #fff;
  border: none;
  border-radius: 14rpx;
  padding: 22rpx 0;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-submit::after { border: none; }

.btn-disabled { background: #d0d0d0; }

.btn-finish {
  flex: 1;
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #fff;
  border: none;
  border-radius: 14rpx;
  padding: 22rpx 0;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-finish::after { border: none; }

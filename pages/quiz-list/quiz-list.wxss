.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.paper-count {
  font-size: 26rpx;
  color: #8e8e93;
}

.toolbar-right {
  display: flex;
  gap: 32rpx;
}

.tool-link {
  font-size: 26rpx;
  color: #07c160;
  font-weight: 500;
}

.paper-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.paper-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.paper-info {
  flex: 1;
}

.paper-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 10rpx;
}

.paper-meta {
  display: flex;
  gap: 24rpx;
}

.paper-count-text, .paper-time {
  font-size: 22rpx;
  color: #8e8e93;
}

.paper-delete {
  padding: 12rpx 20rpx;
}

.delete-text {
  font-size: 24rpx;
  color: #e64340;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 28rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8e8e93;
}

.sample-btn {
  margin-top: 40rpx;
  padding: 20rpx 48rpx;
  background: rgba(7, 193, 96, 0.1);
  border: 1rpx solid rgba(7, 193, 96, 0.3);
  border-radius: 40rpx;
}

.sample-btn:active {
  background: rgba(7, 193, 96, 0.2);
}

.sample-btn-text {
  font-size: 26rpx;
  color: #07c160;
  font-weight: 500;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 100rpx;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #07c160, #06d6a0);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(7, 193, 96, 0.45);
}

.fab-text {
  color: #fff;
  font-size: 56rpx;
  line-height: 1;
  font-weight: 300;
}

/* ======================== 页面基础 ======================== */
.page {
  min-height: 100vh;
  background: #faf9f5;
  padding: 20rpx 24rpx 40rpx;
  font-family: -apple-system, BlinkMacSystemFont, Georgia, 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
  color: #141413;
}

.band-label {
  display: block;
  font-family: Georgia, 'Times New Roman', 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
  font-size: 32rpx;
  font-weight: 400;
  letter-spacing: -3rpx;
  color: #141413;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-family: Georgia, 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
  font-size: 28rpx;
  font-weight: 400;
  letter-spacing: -2rpx;
  color: #141413;
  margin-bottom: 16rpx;
}

.mono {
  font-family: 'SF Mono', 'Menlo', 'Courier New', 'Noto Sans Mono', monospace;
}

/* ======================== 输入区 ======================== */
.input-band {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.input-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 16rpx;
}

.input-label {
  font-size: 22rpx;
  color: #6c6a64;
  margin-bottom: 8rpx;
}

.mono-input {
  background: #faf9f5;
  border-radius: 12rpx;
  padding: 16rpx 18rpx;
  font-size: 24rpx;
  font-family: 'SF Mono', 'Menlo', 'Courier New', 'Noto Sans Mono', monospace;
  color: #141413;
  border: 2rpx solid transparent;
}

.mono-input:focus {
  border-color: #cc785c;
}

.preset-row {
  margin-bottom: 16rpx;
}

.picker-display {
  background: #faf9f5;
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  font-size: 24rpx;
  color: #141413;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.btn-primary {
  flex: 1;
  background: #cc785c;
  color: #faf9f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  border: none;
  text-align: center;
}

.btn-primary:active {
  background: #a9583e;
}

.btn-secondary {
  background: #faf9f5;
  color: #141413;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  border: none;
  min-width: 140rpx;
  text-align: center;
}

.btn-secondary:active {
  background: #e8e0d2;
}

.btn-hover {
  opacity: 0.7;
}

.error-text {
  display: block;
  font-size: 24rpx;
  color: #c0392b;
  margin-top: 8rpx;
}

/* ======================== 步进控制 ======================== */
.ctrl-band {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.ctrl-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.ctrl-label {
  font-size: 24rpx;
  color: #6c6a64;
  min-width: 60rpx;
}

.ctrl-btn {
  background: #faf9f5;
  border-radius: 10rpx;
  padding: 10rpx 20rpx;
  text-align: center;
  font-size: 24rpx;
  color: #141413;
}

.ctrl-sm {
  padding: 8rpx 16rpx;
  min-width: 60rpx;
}

.ctrl-btn:active {
  background: #e8e0d2;
}

.ctrl-value {
  font-size: 26rpx;
  color: #141413;
  min-width: 120rpx;
  text-align: center;
  font-family: 'SF Mono', 'Menlo', 'Courier New', 'Noto Sans Mono', monospace;
}

/* 步骤点的水平排列 */
.step-dots {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
}

.step-dot {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 4rpx;
  border-radius: 10rpx;
  background: #faf9f5;
  opacity: 0.5;
}

.dot-active {
  opacity: 1;
  background: #f5ede2;
  border: 2rpx solid #cc785c;
}

.dot-done {
  opacity: 0.8;
}

.dot-num {
  font-size: 22rpx;
  font-weight: 600;
  color: #141413;
}

.dot-label {
  font-size: 18rpx;
  color: #6c6a64;
  margin-top: 4rpx;
}

/* ======================== 状态矩阵 ======================== */
.matrix-band {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.matrix-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.matrix-cell {
  background: #faf9f5;
  border-radius: 12rpx;
  padding: 14rpx 8rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.cell-modified {
  border-color: #cc785c;
  background: #f5ede2;
}

.cell-hex {
  font-family: 'SF Mono', 'Menlo', 'Courier New', 'Noto Sans Mono', monospace;
  font-size: 28rpx;
  color: #141413;
  font-weight: 600;
}

/* 步进序列 */
.step-sequence {
  display: flex;
  gap: 4rpx;
  margin-top: 8rpx;
}

.seq-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 4rpx;
  border-radius: 10rpx;
  background: #faf9f5;
  opacity: 0.4;
}

.seq-active {
  opacity: 1;
  background: #f5ede2;
  border: 2rpx solid #cc785c;
}

.seq-done {
  opacity: 0.7;
}

.seq-num {
  font-size: 20rpx;
  font-weight: 600;
  color: #141413;
}

.seq-name {
  font-size: 18rpx;
  color: #6c6a64;
  margin-top: 2rpx;
}

/* ======================== 操作详情 ======================== */
.detail-band {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

/* S-box 替换表 */
.sbox-table {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 6rpx;
}

.sbox-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  background: #faf9f5;
  border-radius: 8rpx;
  padding: 6rpx 4rpx;
}

.sbox-before {
  font-family: 'SF Mono', 'Menlo', 'Courier New', 'Noto Sans Mono', monospace;
  font-size: 18rpx;
  color: #6c6a64;
}

.sbox-arrow {
  font-size: 14rpx;
  color: #cc785c;
}

.sbox-after {
  font-family: 'SF Mono', 'Menlo', 'Courier New', 'Noto Sans Mono', monospace;
  font-size: 18rpx;
  color: #141413;
  font-weight: 600;
}

/* ShiftRows */
.shiftrow-line {
  background: #faf9f5;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 8rpx;
}

.shiftrow-text {
  font-size: 24rpx;
  color: #141413;
}

/* MixColumns */
.mixcol-card {
  background: #faf9f5;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.mixcol-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #141413;
  margin-bottom: 8rpx;
  font-family: Georgia, 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
}

.mixcol-formula {
  margin-bottom: 10rpx;
}

.formula-line {
  font-size: 20rpx;
  color: #6c6a64;
  font-family: 'SF Mono', 'Menlo', 'Courier New', 'Noto Sans Mono', monospace;
}

.mixcol-detail {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
}

.mixcol-byte {
  font-family: 'SF Mono', 'Menlo', 'Courier New', 'Noto Sans Mono', monospace;
  font-size: 20rpx;
  color: #6c6a64;
}

.mixcol-result-sign {
  font-size: 20rpx;
  color: #cc785c;
  font-weight: 600;
}

.mixcol-result {
  color: #141413;
  font-weight: 600;
}

/* AddRoundKey */
.roundkey-card {
  background: #faf9f5;
  border-radius: 12rpx;
  padding: 16rpx;
}

.roundkey-text {
  display: block;
  font-family: 'SF Mono', 'Menlo', 'Courier New', 'Noto Sans Mono', monospace;
  font-size: 24rpx;
  color: #141413;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.roundkey-note {
  display: block;
  font-size: 22rpx;
  color: #6c6a64;
  font-style: italic;
}

/* ======================== 加密结果 ======================== */
.result-band {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.result-card {
  background: #faf9f5;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.result-label {
  display: block;
  font-size: 22rpx;
  color: #6c6a64;
  margin-bottom: 8rpx;
}

.result-value {
  font-size: 26rpx;
  color: #141413;
  font-weight: 600;
  word-break: break-all;
}

.result-key {
  font-size: 22rpx;
  color: #6c6a64;
}

.result-ct {
  color: #cc785c;
}

/* ======================== 密钥扩展面板 ======================== */
.keyexp-band {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.keyexp-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.keyexp-toggle {
  font-size: 24rpx;
  color: #6c6a64;
}

.keyexp-body {
  margin-top: 16rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.keyexp-word {
  background: #faf9f5;
  border-radius: 10rpx;
  padding: 12rpx 14rpx;
  margin-bottom: 8rpx;
}

.word-special {
  border-left: 6rpx solid #cc785c;
}

.word-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.word-idx {
  font-family: 'SF Mono', 'Menlo', 'Courier New', 'Noto Sans Mono', monospace;
  font-size: 22rpx;
  font-weight: 600;
  color: #141413;
}

.word-type {
  font-size: 18rpx;
  color: #6c6a64;
}

.word-hex {
  font-family: 'SF Mono', 'Menlo', 'Courier New', 'Noto Sans Mono', monospace;
  font-size: 22rpx;
  color: #141413;
  word-break: break-all;
}

.word-detail {
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 2rpx solid #e6dfd8;
}

.word-detail-text {
  display: block;
  font-family: 'SF Mono', 'Menlo', 'Courier New', 'Noto Sans Mono', monospace;
  font-size: 18rpx;
  color: #6c6a64;
  margin-bottom: 4rpx;
}

/* ======================== 空状态 ======================== */
.empty-band {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 48rpx 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 26rpx;
  color: #8e8b82;
}

/* ── AES 帮助触发器 ── */

.aes-help-trigger {
  position: fixed;
  right: 24rpx;
  bottom: 120rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #cc785c;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.aes-help-trigger:active {
  background: #a9583e;
  transform: scale(0.92);
}

.aes-help-trigger-icon {
  font-family: Georgia, 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
}

/* ── AES 侧边面板 ── */

.aes-help-panel {
  position: fixed;
  top: 0;
  right: 0;
  width: 450rpx;
  height: 100vh;
  background: #efe9de;
  z-index: 150;
  transform: translateX(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
  box-shadow: -4rpx 0 20rpx rgba(0,0,0,0.06);
}

.aes-help-open {
  transform: translateX(0);
}

.aes-help-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #ddd7cc;
}

.aes-help-title {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  font-weight: 600;
  color: #141413;
}

.aes-help-close {
  font-size: 28rpx;
  color: #6c6a64;
  padding: 8rpx;
}

.aes-help-body {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

.aes-help-section {
  margin-bottom: 28rpx;
}

.aes-help-step {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', sans-serif;
  font-size: 26rpx;
  font-weight: 600;
  color: #cc785c;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.aes-help-desc {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', sans-serif;
  font-size: 24rpx;
  color: #141413;
  line-height: 1.6;
}

<view class="page">
  <!-- 密钥生成区 -->
  <view class="card">
    <text class="card-title">第一步：密钥生成</text>
    <text class="card-desc">输入或选择两个不同的素数 p 和 q</text>

    <view class="prime-row">
      <view class="prime-field">
        <text class="field-label">素数 p</text>
        <view class="input-group">
          <picker class="picker" mode="selector" range="{{primeList}}" range-key="label" bindchange="onPSelect">
            <view class="picker-btn">▼ 选素数</view>
          </picker>
          <input class="input {{pError ? 'input-error' : ''}}" type="digit" value="{{inputP}}" bindinput="onPInput" placeholder="输入 p" />
          <button class="btn-random" bindtap="onRandomP">🎲</button>
        </view>
        <text class="error-text" wx:if="{{pError}}">{{pError}}</text>
      </view>

      <view class="prime-field">
        <text class="field-label">素数 q</text>
        <view class="input-group">
          <picker class="picker" mode="selector" range="{{primeList}}" range-key="label" bindchange="onQSelect">
            <view class="picker-btn">▼ 选素数</view>
          </picker>
          <input class="input {{qError ? 'input-error' : ''}}" type="digit" value="{{inputQ}}" bindinput="onQInput" placeholder="输入 q" />
          <button class="btn-random" bindtap="onRandomQ">🎲</button>
        </view>
        <text class="error-text" wx:if="{{qError}}">{{qError}}</text>
      </view>
    </view>

    <button class="btn-primary" bindtap="onGenerateKeypair">生成密钥对</button>

    <!-- 密钥展示 -->
    <view class="key-display" wx:if="{{keypair}}">
      <view class="key-grid">
        <view class="key-item">
          <text class="key-label">n = p × q</text>
          <text class="key-value">{{keypair.n}}</text>
        </view>
        <view class="key-item">
          <text class="key-label">φ(n) = (p-1)(q-1)</text>
          <text class="key-value">{{keypair.phi}}</text>
        </view>
        <view class="key-item">
          <text class="key-label">公钥 e</text>
          <text class="key-value highlight-e">{{keypair.e}}</text>
        </view>
        <view class="key-item">
          <text class="key-label">私钥 d</text>
          <text class="key-value highlight-d">{{keypair.d}}</text>
        </view>
      </view>
      <view class="key-check {{(keypair.e * keypair.d) % keypair.phi === 1 ? 'check-ok' : 'check-fail'}}">
        <text>校验：{{keypair.e}} × {{keypair.d}} ≡ {{(keypair.e * keypair.d) % keypair.phi}} (mod {{keypair.phi}})</text>
        <text wx:if="{{(keypair.e * keypair.d) % keypair.phi === 1}}"> ✅</text>
        <text wx:else=""> ❌</text>
      </view>
      <text class="wiener-warning" wx:if="{{wienerWarning}}">⚠️ {{wienerWarning}}</text>
      <block wx:for="{{weakKeyWarnings}}" wx:key="index">
        <text class="wiener-warning">⚠️ {{item}}</text>
      </block>
    </view>
  </view>

  <!-- 加密/解密区 -->
  <view class="card" wx:if="{{keypair}}">
    <text class="card-title">第二步：加密 / 解密</text>

    <view class="crypto-row">
      <view class="crypto-section">
        <text class="field-label">加密</text>
        <input class="input" type="digit" value="{{plaintext}}" bindinput="onPlaintextInput" placeholder="明文 (0 ≤ m < {{keypair.n}})" />
        <button class="btn-primary btn-small" bindtap="onEncrypt">加密</button>
        <text class="result-text" wx:if="{{encrypted !== null}}">
          {{plaintext}}^{{keypair.e}} mod {{keypair.n}} = <text class="result-value">{{encrypted}}</text>
        </text>
      </view>

      <view class="crypto-section">
        <text class="field-label">解密</text>
        <input class="input" type="digit" value="{{ciphertext}}" bindinput="onCiphertextInput" placeholder="密文" />
        <button class="btn-primary btn-small" bindtap="onDecrypt">解密</button>
        <text class="result-text" wx:if="{{decrypted !== null}}">
          {{ciphertext}}^{{keypair.d}} mod {{keypair.n}} = <text class="result-value">{{decrypted}}</text>
        </text>
      </view>
    </view>

    <!-- 模幂过程 -->
    <view class="detail-section" wx:if="{{modPowSteps}}">
      <view class="detail-header" bindtap="onToggleDetails">
        <text class="detail-toggle {{showDetails ? 'expanded' : ''}}">▶</text>
        <text>查看模幂运算过程</text>
      </view>
      <view class="detail-body" wx:if="{{showDetails}}">
        <text class="step-title">计算 {{modPowLabel}}</text>
        <text class="step-subtitle">{{modPowSteps.exp}} 的二进制：{{modPowSteps.binary}}</text>
        <view class="step-table">
          <view class="step-row step-header">
            <text class="step-cell step-cell-bit">当前比特</text>
            <text class="step-cell step-cell-val">base 值</text>
            <text class="step-cell step-cell-res">result</text>
          </view>
          <view class="step-row" wx:for="{{modPowSteps.steps}}" wx:key="index">
            <text class="step-cell step-cell-bit">{{item.bit}}</text>
            <text class="step-cell step-cell-val">{{item.value}}</text>
            <text class="step-cell step-cell-res">{{item.result}}</text>
          </view>
        </view>
        <text class="final-result">最终结果：{{modPowSteps.final}}</text>
      </view>
    </view>

    <!-- 文字模式 -->
    <view class="text-mode-section">
      <text class="field-label">文字模式（ASCII）</text>
      <view class="text-mode-row">
        <input class="input input-text" type="text" value="{{textModePlain}}" bindinput="onTextModePlainInput" placeholder="输入 ASCII 文本" />
        <picker class="picker" mode="selector" range="{{['encrypt', 'decrypt']}}" bindchange="onTextModeTypeChange">
          <view class="picker-btn">{{textModeType === 'encrypt' ? '加密' : '解密'}}</view>
        </picker>
        <button class="btn-primary btn-small" bindtap="onTextModeRun">执行</button>
        <button class="btn-secondary btn-small" bindtap="onTextModeClear">清空</button>
      </view>
      <view class="text-mode-result" wx:if="{{textModeResult}}">
        <view class="text-mode-result-row text-mode-result-header">
          <text class="tm-cell tm-cell-char">字符</text>
          <text class="tm-cell tm-cell-code">ASCII</text>
          <text class="tm-cell tm-cell-out">{{textModeType === 'encrypt' ? '密文' : '明文'}}</text>
        </view>
        <view class="text-mode-result-row" wx:for="{{textModeResult}}" wx:key="index">
          <text class="tm-cell tm-cell-char">{{item.char}}</text>
          <text class="tm-cell tm-cell-code">{{item.code}}</text>
          <text class="tm-cell tm-cell-out">{{item.out}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 数论细节面板 -->
  <view class="card" wx:if="{{keypair}}">
    <text class="card-title">第三步：数论中间过程</text>

    <view class="detail-section">
      <view class="detail-header" bindtap="onToggleDetails">
        <text class="detail-toggle {{showDetails ? 'expanded' : ''}}">▶</text>
        <text>φ(n) 计算</text>
      </view>
      <view class="detail-body" wx:if="{{showDetails}}">
        <text class="formula-line">φ(n) = ({{keypair.p}}-1)({{keypair.q}}-1)</text>
        <text class="formula-line">= {{keypair.p-1}} × {{keypair.q-1}}</text>
        <text class="formula-line formula-result">= {{keypair.phi}}</text>
      </view>
    </view>

    <view class="detail-section">
      <view class="detail-header" bindtap="onToggleEeDetails">
        <text class="detail-toggle {{showEeDetails ? 'expanded' : ''}}">▶</text>
        <text>扩展欧几里得求模逆</text>
      </view>
      <view class="detail-body" wx:if="{{showEeDetails && keypair.steps && keypair.steps.extendedEuclid.steps}}">
        <text class="step-title">Euclidean 除法步骤</text>
        <view class="ee-steps">
          <view class="ee-step" wx:for="{{keypair.steps.extendedEuclid.steps}}" wx:key="index" wx:for-index="idx">
            <text class="ee-step-num">step {{idx + 1}}</text>
            <text class="ee-step-eq">{{item.dividend}} = {{item.quotient}}×{{item.divisor}} + {{item.remainder}}</text>
          </view>
        </view>
        <text class="formula-line" wx:if="{{keypair.steps.extendedEuclid.gcd === 1}}">→ gcd = 1，存在模逆</text>
        <text class="formula-line">{{keypair.steps.extendedEuclid.detail}}</text>
        <text class="formula-line formula-result">d ≡ {{keypair.e}}⁻¹ (mod {{keypair.phi}}) = {{keypair.d}}</text>
        <text class="verify-line">验证：{{keypair._verifyDetail}}</text>
      </view>
    </view>
  </view>
</view>

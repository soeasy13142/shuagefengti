/* ── 页面基础 ── */
.page {
  min-height: 100vh;
  background-color: #faf9f5;
  padding: 32rpx 24rpx 48rpx;
}

/* ── 卡片 ── */
.card {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  display: block;
  font-family: Georgia, 'Times New Roman', 'Songti SC', 'Noto Serif CJK SC', 'STSong', 'SimSun', serif;
  font-size: 32rpx;
  font-weight: 400;
  letter-spacing: -1rpx;
  color: #141413;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 26rpx;
  color: #6c6a64;
  margin-bottom: 24rpx;
}

/* ── 素数输入行 ── */
.prime-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.prime-field {
  flex: 1;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #6c6a64;
  margin-bottom: 8rpx;
}

.input-group {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.input {
  flex: 1;
  height: 72rpx;
  background: #faf9f5;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #141413;
}

.input-error {
  border: 2rpx solid #e74c3c;
}

.picker {
  flex-shrink: 0;
}

.picker-btn {
  background: #faf9f5;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  color: #6c6a64;
}

.btn-random {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  background: #faf9f5;
  border-radius: 12rpx;
  padding: 0;
  font-size: 32rpx;
  line-height: 72rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.error-text {
  display: block;
  font-size: 24rpx;
  color: #e74c3c;
  margin-top: 6rpx;
}

/* ── 按钮 ── */
.btn-primary {
  background: #cc785c;
  color: #faf9f5;
  font-size: 28rpx;
  border-radius: 16rpx;
  padding: 20rpx 32rpx;
  text-align: center;
  border: none;
  margin-bottom: 16rpx;
}

.btn-primary:active {
  background: #a9583e;
}

.btn-small {
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  display: inline-block;
  width: auto;
  margin: 8rpx 0;
}

.btn-secondary {
  background: #d9d3c8;
  color: #141413;
  font-size: 26rpx;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  text-align: center;
  border: none;
  display: inline-block;
  width: auto;
}

/* ── 密钥展示 ── */
.key-display {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #d9d3c8;
}

.key-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.key-item {
  flex: 1;
  min-width: 120rpx;
  background: #faf9f5;
  border-radius: 12rpx;
  padding: 16rpx;
}

.key-label {
  display: block;
  font-size: 24rpx;
  color: #6c6a64;
  margin-bottom: 4rpx;
}

.key-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #141413;
  font-family: 'Courier New', 'Noto Sans Mono', monospace;
}

.highlight-e {
  color: #cc785c;
}

.highlight-d {
  color: #2e86ab;
}

.key-check {
  font-size: 26rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.check-ok {
  background: #eafaf1;
  color: #27ae60;
}

.check-fail {
  background: #fdedec;
  color: #e74c3c;
}

.wiener-warning {
  display: block;
  font-size: 24rpx;
  color: #e67e22;
  background: #fef5e7;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
}

/* ── 加密/解密 ── */
.crypto-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.crypto-section {
  flex: 1;
  background: #faf9f5;
  border-radius: 16rpx;
  padding: 20rpx;
}

.result-text {
  display: block;
  font-size: 28rpx;
  color: #141413;
  margin-top: 12rpx;
  font-family: 'Courier New', 'Noto Sans Mono', monospace;
}

.result-value {
  color: #cc785c;
  font-weight: 600;
}

/* ── 模幂过程 ── */
.detail-section {
  margin-top: 16rpx;
}

.detail-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #6c6a64;
}

.detail-toggle {
  font-size: 24rpx;
  color: #6c6a64;
  transition: transform 0.2s;
}

.detail-toggle.expanded {
  transform: rotate(90deg);
}

.detail-body {
  background: #faf9f5;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 8rpx;
}

.step-title {
  display: block;
  font-size: 28rpx;
  color: #141413;
  margin-bottom: 8rpx;
}

.step-subtitle {
  display: block;
  font-size: 24rpx;
  color: #6c6a64;
  margin-bottom: 16rpx;
}

.step-table {
  display: flex;
  flex-direction: column;
  border: 2rpx solid #d9d3c8;
  border-radius: 12rpx;
  overflow: hidden;
}

.step-row {
  display: flex;
  flex-direction: row;
  border-bottom: 2rpx solid #d9d3c8;
}

.step-row:last-child {
  border-bottom: none;
}

.step-header {
  background: #d9d3c8;
  font-weight: 600;
}

.step-cell {
  flex: 1;
  padding: 12rpx 16rpx;
  font-size: 24rpx;
  color: #141413;
  font-family: 'Courier New', 'Noto Sans Mono', monospace;
  text-align: center;
}

.step-cell-bit {
  flex: 0.5;
}

.final-result {
  display: block;
  font-size: 28rpx;
  color: #cc785c;
  font-weight: 600;
  margin-top: 16rpx;
  font-family: 'Courier New', 'Noto Sans Mono', monospace;
}

/* ── 数论公式 ── */
.formula-line {
  display: block;
  font-size: 28rpx;
  color: #141413;
  margin-bottom: 8rpx;
  font-family: 'Courier New', 'Noto Sans Mono', monospace;
}

.formula-result {
  color: #cc785c;
  font-weight: 600;
  font-size: 32rpx;
}

.verify-line {
  display: block;
  font-size: 26rpx;
  color: #6c6a64;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #d9d3c8;
  font-family: 'Courier New', 'Noto Sans Mono', monospace;
}

/* ── 文字模式 ── */
.text-mode-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #d9d3c8;
}

.text-mode-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.input-text {
  flex: 2;
  min-width: 200rpx;
}

.text-mode-result {
  background: #faf9f5;
  border-radius: 16rpx;
  padding: 16rpx;
}

.text-mode-result-row {
  display: flex;
  flex-direction: row;
  border-bottom: 2rpx solid #d9d3c8;
  padding: 8rpx 0;
}

.text-mode-result-row:last-child {
  border-bottom: none;
}

.text-mode-result-header {
  font-weight: 600;
  color: #6c6a64;
}

.tm-cell {
  flex: 1;
  font-size: 26rpx;
  color: #141413;
  text-align: center;
  font-family: 'Courier New', 'Noto Sans Mono', monospace;
}

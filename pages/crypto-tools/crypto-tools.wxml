<!-- 密码工具箱页面 -->
<view class="page">
  <!-- Tab 切换栏 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'caesar' ? 'tab-active' : ''}}" data-tab="caesar" bindtap="onTabSwitch">
      <text class="tab-label">凯撒</text>
    </view>
    <view class="tab-item {{activeTab === 'vigenere' ? 'tab-active' : ''}}" data-tab="vigenere" bindtap="onTabSwitch">
      <text class="tab-label">维吉尼亚</text>
    </view>
    <view class="tab-item {{activeTab === 'railfence' ? 'tab-active' : ''}}" data-tab="railfence" bindtap="onTabSwitch">
      <text class="tab-label">栅栏</text>
    </view>
  </view>

  <!-- === 凯撒密码 Tab === -->
  <view wx:if="{{activeTab === 'caesar'}}" class="tab-content">
    <view class="card">
      <view class="section-title">参数设置</view>
      <view class="control-row">
        <text class="control-label">移位 (1-25)：</text>
        <input class="shift-input" type="number" min="1" max="25" value="{{caesarShift}}" bindinput="onCaesarShiftInput" />
      </view>
      <view class="btn-row">
        <button class="btn btn-primary" bindtap="onCaesarEncrypt">加密</button>
        <button class="btn btn-secondary" bindtap="onCaesarDecrypt">解密</button>
      </view>
    </view>

    <view class="card">
      <view class="section-title">输入文本</view>
      <picker class="preset-picker" bindchange="onPresetSelect" data-tab="caesar">
        <view class="preset-trigger">选择预设文本 ›</view>
      </picker>
      <textarea class="text-input" value="{{caesarInput}}" bindinput="onCaesarInput" placeholder="输入要加密/解密的文本..." maxlength="{{maxInputLength}}" auto-height />
      <text class="char-count">{{caesarInput.length}}/{{maxInputLength}}</text>
    </view>

    <view wx:if="{{caesarResult}}" class="card">
      <view class="section-title">结果</view>
      <view class="result-box">
        <text>{{caesarResult}}</text>
      </view>
    </view>

    <!-- 暴力破解 -->
    <view class="card collapsible">
      <view class="collapsible-header" bindtap="onCaesarToggleBruteForce">
        <text class="collapsible-icon">{{caesarShowBruteForce ? '▼' : '▶'}}</text>
        <text>暴力破解 (25 种移位)</text>
      </view>
      <view wx:if="{{caesarShowBruteForce}}" class="collapsible-body">
        <scroll-view class="brute-scroll" scroll-y>
          <view wx:for="{{caesarBruteForceResults}}" wx:key="shift" class="brute-item">
            <text class="brute-shift">Shift {{item.shift}}:</text>
            <text class="brute-result">{{item.result}}</text>
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- 字母频率分析 -->
    <view class="card collapsible">
      <view class="collapsible-header" bindtap="onCaesarToggleFreq">
        <text class="collapsible-icon">{{caesarShowFreq ? '▼' : '▶'}}</text>
        <text>字母频率分析</text>
      </view>
      <view wx:if="{{caesarShowFreq}}" class="collapsible-body">
        <view class="freq-chart">
          <view wx:for="{{caesarFreqResults}}" wx:key="letter" class="freq-row">
            <text class="freq-letter">{{item.letter}}</text>
            <view class="freq-bar-bg">
              <view class="freq-bar" style="width: {{item.pct * 6}}px;"></view>
            </view>
            <text class="freq-pct">{{item.pct}}%</text>
            <!-- 标准频率对比 -->
            <view class="freq-bar-bg freq-std-bg">
              <view class="freq-bar freq-std-bar" style="width: {{caesarStdFreq[item.letter].pct * 6}}px;"></view>
            </view>
          </view>
        </view>
        <view class="freq-legend">
          <view class="legend-item"><view class="legend-swatch legend-input"></view>输入文本</view>
          <view class="legend-item"><view class="legend-swatch legend-std"></view>标准英文</view>
        </view>
      </view>
    </view>
  </view>

  <!-- === 维吉尼亚密码 Tab === -->
  <view wx:elif="{{activeTab === 'vigenere'}}" class="tab-content">
    <view class="card">
      <view class="section-title">参数设置</view>
      <view class="control-row">
        <text class="control-label">密钥：</text>
        <input class="key-input" value="{{vigenereKey}}" bindinput="onVigenereKeyInput" placeholder="输入密钥（仅字母）" />
      </view>
      <view class="btn-row">
        <button class="btn btn-primary" bindtap="onVigenereEncrypt">加密</button>
        <button class="btn btn-secondary" bindtap="onVigenereDecrypt">解密</button>
      </view>
    </view>

    <view class="card">
      <view class="section-title">输入文本</view>
      <picker class="preset-picker" bindchange="onPresetSelect" data-tab="vigenere">
        <view class="preset-trigger">选择预设文本 ›</view>
      </picker>
      <textarea class="text-input" value="{{vigenereInput}}" bindinput="onVigenereInput" placeholder="输入要加密/解密的文本..." maxlength="{{maxInputLength}}" auto-height />
      <text class="char-count">{{vigenereInput.length}}/{{maxInputLength}}</text>
    </view>

    <view wx:if="{{vigenereResult}}" class="card">
      <view class="section-title">结果</view>
      <view class="result-box">
        <text>{{vigenereResult}}</text>
      </view>
    </view>

    <!-- 逐字母偏移对照 -->
    <view class="card collapsible">
      <view class="collapsible-header" bindtap="onVigenereToggleSteps">
        <text class="collapsible-icon">{{vigenereShowSteps ? '▼' : '▶'}}</text>
        <text>偏移过程</text>
      </view>
      <view wx:if="{{vigenereShowSteps && vigenereStepData}}" class="collapsible-body">
        <view class="step-section">
          <text class="step-label">密钥循环：</text>
          <text class="step-value">{{vigenereStepData.keyRepeated}}</text>
        </view>
        <scroll-view class="step-scroll" scroll-y>
          <view class="step-table">
            <view class="step-header">
              <text class="step-col step-col-input">输入</text>
              <text class="step-col step-col-key">密钥</text>
              <text class="step-col step-col-offset">偏移</text>
              <text class="step-col step-col-output">输出</text>
            </view>
            <view wx:for="{{vigenereStepData.mapping}}" wx:key="*this" class="step-row">
              <text class="step-col step-col-input">{{item.input}}</text>
              <text class="step-col step-col-key">{{item.keyChar}}</text>
              <text class="step-col step-col-offset">{{item.offset}}</text>
              <text class="step-col step-col-output">{{item.output}}</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>

  <!-- === 栅栏密码 Tab === -->
  <view wx:elif="{{activeTab === 'railfence'}}" class="tab-content">
    <view class="card">
      <view class="section-title">参数设置</view>
      <view class="control-row">
        <text class="control-label">栏数 (2-20)：</text>
        <input class="shift-input" type="number" min="2" max="20" value="{{railFenceRails}}" bindinput="onRailFenceRailsInput" />
      </view>
      <view class="btn-row">
        <button class="btn btn-primary" bindtap="onRailFenceEncrypt">加密</button>
        <button class="btn btn-secondary" bindtap="onRailFenceDecrypt">解密</button>
      </view>
    </view>

    <view class="card">
      <view class="section-title">输入文本</view>
      <picker class="preset-picker" bindchange="onPresetSelect" data-tab="railfence">
        <view class="preset-trigger">选择预设文本 ›</view>
      </picker>
      <textarea class="text-input" value="{{railFenceInput}}" bindinput="onRailFenceInput" placeholder="输入要加密/解密的文本..." maxlength="{{maxInputLength}}" auto-height />
      <text class="char-count">{{railFenceInput.length}}/{{maxInputLength}}</text>
    </view>

    <view wx:if="{{railFenceResult}}" class="card">
      <view class="section-title">结果</view>
      <view class="result-box">
        <text>{{railFenceResult}}</text>
      </view>
    </view>

    <!-- 栅栏结构可视化 -->
    <view class="card collapsible">
      <view class="collapsible-header" bindtap="onRailFenceToggleStructure">
        <text class="collapsible-icon">{{railFenceShowStructure ? '▼' : '▶'}}</text>
        <text>栅栏结构</text>
      </view>
      <view wx:if="{{railFenceShowStructure && railFenceStructureData}}" class="collapsible-body">
        <scroll-view class="structure-scroll" scroll-x>
          <view wx:for="{{railFenceStructureData.grid}}" wx:for-item="row" wx:key="*this" class="structure-row">
            <view wx:for="{{row}}" wx:for-item="cell" wx:key="*this" class="structure-cell {{cell ? 'structure-cell-filled' : ''}}">
              <text>{{cell || '.'}}</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- 暴力枚举栏数 -->
    <view class="card collapsible">
      <view class="collapsible-header" bindtap="onRailFenceToggleBruteForce">
        <text class="collapsible-icon">{{railFenceShowBruteForce ? '▼' : '▶'}}</text>
        <text>暴力枚举栏数 (2-20)</text>
      </view>
      <view wx:if="{{railFenceShowBruteForce}}" class="collapsible-body">
        <scroll-view class="brute-scroll" scroll-y>
          <view wx:for="{{railFenceBruteForceResults}}" wx:key="rails" class="brute-item">
            <text class="brute-shift">Rails {{item.rails}}:</text>
            <text class="brute-result">{{item.result}}</text>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>
</view>

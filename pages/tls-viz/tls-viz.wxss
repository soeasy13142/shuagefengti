/* ======================== 页面基础 ======================== */
.page {
  min-height: 100vh;
  background: #faf9f5;
  padding: 20rpx 24rpx 40rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Georgia', serif;
  color: #141413;
}

.band-label {
  display: block;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 32rpx;
  font-weight: 400;
  letter-spacing: -3rpx;
  color: #141413;
  margin-bottom: 16rpx;
}

.error-text {
  display: block;
  margin-top: 12rpx;
  color: #c0392b;
  font-size: 24rpx;
}

/* ======================== 配置区 ======================== */
.config-band {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.config-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.config-label {
  font-size: 24rpx;
  color: #6c6a64;
  flex-shrink: 0;
  width: 80rpx;
}

.scenario-picker {
  background: #faf9f5;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #141413;
  flex: 1;
}

.picker-arrow {
  color: #6c6a64;
}

.scenario-desc {
  display: block;
  font-size: 22rpx;
  color: #6c6a64;
  line-height: 1.5;
  margin-top: 8rpx;
}

/* ======================== 交互图 ======================== */
.diagram-band {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.diagram-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 220rpx;
  position: relative;
}

.endpoint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  z-index: 2;
  flex-shrink: 0;
}

.endpoint-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.client-icon {
  background: #cc785c;
}

.server-icon {
  background: #5c7acc;
}

.endpoint-label {
  font-size: 24rpx;
  color: #141413;
  font-weight: 600;
}

.message-lane {
  flex: 1;
  min-height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin: 0 16rpx;
}

.message-arrow {
  position: relative;
  animation: fadeSlideIn 0.4s ease;
}

@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.message-bubble {
  background: #faf9f5;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  max-width: 320rpx;
  text-align: center;
}

.message-bubble.msg-alert {
  border: 2rpx solid #c0392b;
  background: #fce8e8;
}

.message-bubble.msg-key {
  border: 2rpx solid #7a9c5c;
  background: #f0f5ea;
}

.message-label {
  font-size: 24rpx;
  color: #141413;
  font-weight: 600;
}

.message-placeholder {
  text-align: center;
}

.placeholder-text {
  font-size: 22rpx;
  color: #8e8b82;
}

/* ======================== 进度条 ======================== */
.progress-band {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #efe9de;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #cc785c;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.step-counter {
  font-size: 22rpx;
  color: #6c6a64;
  font-family: 'SF Mono', 'Menlo', monospace;
  flex-shrink: 0;
  width: 80rpx;
  text-align: right;
}

/* ======================== 详情 ======================== */
.detail-band {
  background: #efe9de;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.detail-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.detail-step-label {
  font-size: 32rpx;
  font-weight: 700;
  font-family: Georgia, serif;
  color: #141413;
  letter-spacing: -2rpx;
}

.detail-direction {
  font-size: 20rpx;
  color: #6c6a64;
}

.detail-explanation {
  font-size: 24rpx;
  color: #141413;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

/* ======================== 字段列表 ======================== */
.fields-list {
  background: #faf9f5;
  border-radius: 16rpx;
  padding: 8rpx 16rpx;
  margin-bottom: 16rpx;
}

.field-row {
  display: flex;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #e6dfd8;
}

.field-row:last-child {
  border-bottom: none;
}

.field-row.field-highlight {
  background: #ffe8d6;
  margin: 0 -16rpx;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.field-name {
  font-size: 22rpx;
  color: #6c6a64;
  width: 140rpx;
  flex-shrink: 0;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.field-value {
  font-size: 24rpx;
  color: #141413;
  font-family: 'SF Mono', 'Menlo', monospace;
  word-break: break-all;
  flex: 1;
}

.field-note {
  font-size: 20rpx;
  color: #8e8b82;
  width: 100%;
  padding-left: 140rpx;
}

/* ======================== 证书链 ======================== */
.cert-chain {
  background: #faf9f5;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.cert-chain-label {
  display: block;
  font-size: 22rpx;
  color: #6c6a64;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.cert-item {
  display: flex;
  align-items: center;
  padding: 6rpx 0;
  font-size: 22rpx;
}

.cert-indent {
  color: #8e8b82;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.cert-subject {
  color: #141413;
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* ======================== 密钥派生 ======================== */
.key-derive-band {
  background: #f0f5ea;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #d0dfc0;
}

.key-derive-title {
  display: block;
  font-size: 22rpx;
  color: #5a7a3a;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
  font-weight: 600;
}

.key-grid {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.key-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.key-name {
  font-size: 20rpx;
  color: #6c6a64;
  width: 110rpx;
  flex-shrink: 0;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.key-value {
  font-size: 18rpx;
  color: #3a5a2a;
  font-family: 'SF Mono', 'Menlo', monospace;
  word-break: break-all;
}

/* ======================== 面试考点 ======================== */
.exam-tip {
  background: #f5ede2;
  border-radius: 12rpx;
  padding: 16rpx;
  border-left: 4rpx solid #cc785c;
}

.exam-tip-label {
  display: block;
  font-size: 22rpx;
  color: #cc785c;
  margin-bottom: 8rpx;
  font-weight: bold;
}

.exam-tip-text {
  display: block;
  font-size: 24rpx;
  color: #141413;
  line-height: 1.6;
}

/* ======================== 完成状态 ======================== */
.summary-band {
  background: #cc785c;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

.summary-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  font-family: Georgia, serif;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: -2rpx;
}

.summary-text {
  display: block;
  font-size: 24rpx;
  color: #f5ede2;
  line-height: 1.6;
}

/* ======================== 控制栏 ======================== */
.ctrl-band {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #efe9de;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 40rpx;
}

.ctrl-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #faf9f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ctrl-btn:active { background: #e8e0d2; }

.ctrl-play {
  background: #cc785c;
  width: 88rpx;
  height: 88rpx;
}

.ctrl-play:active { background: #a9583e; }

.ctrl-play .ctrl-icon { color: #fff; font-size: 32rpx; }

.ctrl-icon {
  font-size: 28rpx;
  color: #141413;
}

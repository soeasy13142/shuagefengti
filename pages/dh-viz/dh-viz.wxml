<view class="page">
  <!-- ===== 顶部参数区 ===== -->
  <view class="config-card">
    <text class="card-title">公共参数</text>

    <view class="param-row">
      <text class="param-label">素数 p</text>
      <picker class="param-picker" mode="selector" range="{{presetPrimes}}" value="{{presetPrimes.indexOf(p)}}" bindchange="onPrimeChange">
        <view class="picker-value">{{p}}</view>
      </picker>
    </view>

    <view class="param-row">
      <text class="param-label">本原根 g</text>
      <picker class="param-picker" mode="selector" range="{{availableRoots}}" value="{{availableRoots.indexOf(g)}}" bindchange="onGChange">
        <view class="picker-value">{{g}}</view>
      </picker>
      <text class="param-helper">共 {{availableRoots.length}} 个本原根</text>
    </view>

    <view class="param-row">
      <text class="param-label">场景</text>
      <picker class="param-picker" mode="selector" range="{{['正常交换', 'MITM 攻击']}}" value="{{scene === 'mitm' ? 1 : 0}}" bindchange="onSceneChange">
        <view class="picker-value">{{scene === 'mitm' ? 'MITM 攻击' : '正常交换'}}</view>
      </picker>
    </view>

    <view class="action-row">
      <button class="btn-primary" bindtap="onStartExchange" hover-class="btn-hover" wx:if="{{!isPlaying || currentStep === 0}}">▶ 开始交换</button>
      <button class="btn-primary" bindtap="onPause" hover-class="btn-hover" wx:if="{{isPlaying && currentStep > 0 && currentStep < totalSteps}}">⏸ 暂停</button>
      <button class="btn-primary" bindtap="onResume" hover-class="btn-hover" wx:if="{{!isPlaying && currentStep > 0 && currentStep < totalSteps}}">▶ 继续</button>
      <button class="btn-secondary" bindtap="onReset" hover-class="btn-hover">↻ 重置</button>
    </view>
  </view>

  <!-- ===== 主视图：双方面板 ===== -->
  <view class="panels-wrapper" wx:if="{{hasExchanged}}">
    <!-- Alice 面板 -->
    <view class="panel-card panel-alice">
      <text class="panel-title">Alice</text>
      <view class="panel-body">
        <view class="key-row">
          <text class="key-label">私钥 a</text>
          <input class="key-input" type="number" value="{{alice.privateKey}}" bindinput="onAlicePrivInput" disabled="{{hasExchanged}}" />
          <button class="btn-small" bindtap="onRandomAlice" wx:if="{{!hasExchanged}}">🎲</button>
        </view>
        <view class="calc-row">
          <text class="calc-label">公钥 A = g^a mod p</text>
          <text class="calc-expr">{{g}}^{{alice.privateKey}} mod {{p}}</text>
          <text class="calc-result">= {{alice.publicKey}}</text>
        </view>
        <view class="key-received">
          <text class="key-label">收到的公钥</text>
          <text class="key-value">{{alice.receivedPublicKey || '—'}}</text>
        </view>
        <view class="calc-row" wx:if="{{alice.sharedKey > 0}}">
          <text class="calc-label">共享密钥 K = B^a mod p</text>
          <text class="calc-result">= {{alice.sharedKey}}</text>
        </view>
      </view>
    </view>

    <!-- MITM: Eve 中间面板 -->
    <view class="panel-eve" wx:if="{{scene === 'mitm' && eve}}">
      <view class="eve-body">
        <text class="eve-title">Eve (中间人)</text>
        <text class="eve-desc">拦截并篡改公钥</text>
        <view class="eve-detail">
          <text>Eve 私钥 e = {{eve.privateKey}}</text>
          <text>公钥 E = g^e mod p = {{eve.publicKey}}</text>
          <text>K_ae = {{eve.sharedKeyAlice}}</text>
          <text>K_be = {{eve.sharedKeyBob}}</text>
        </view>
      </view>
      <view class="eve-arrow-left">← 拦截 Alice</view>
      <view class="eve-arrow-right">拦截 Bob →</view>
    </view>

    <!-- Bob 面板 -->
    <view class="panel-card panel-bob">
      <text class="panel-title">Bob</text>
      <view class="panel-body">
        <view class="key-row">
          <text class="key-label">私钥 b</text>
          <input class="key-input" type="number" value="{{bob.privateKey}}" bindinput="onBobPrivInput" disabled="{{hasExchanged}}" />
          <button class="btn-small" bindtap="onRandomBob" wx:if="{{!hasExchanged}}">🎲</button>
        </view>
        <view class="calc-row">
          <text class="calc-label">公钥 B = g^b mod p</text>
          <text class="calc-expr">{{g}}^{{bob.privateKey}} mod {{p}}</text>
          <text class="calc-result">= {{bob.publicKey}}</text>
        </view>
        <view class="key-received">
          <text class="key-label">收到的公钥</text>
          <text class="key-value">{{bob.receivedPublicKey || '—'}}</text>
        </view>
        <view class="calc-row" wx:if="{{bob.sharedKey > 0}}">
          <text class="calc-label">共享密钥 K = A^b mod p</text>
          <text class="calc-result">= {{bob.sharedKey}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 密钥一致性验证 ===== -->
  <view class="verify-band" wx:if="{{hasExchanged && alice && bob}}">
    <text wx:if="{{scene === 'mitm'}}" class="verify-warn">⚠️ MITM 攻击：Alice 和 Bob 的共享密钥不一致！</text>
    <text wx:elif="{{keysMatch}}" class="verify-ok">✅ 双方共享密钥一致：{{alice.sharedKey}}</text>
    <text wx:else class="verify-warn">⚠️ 共享密钥不一致！</text>
  </view>

  <!-- ===== 步进控制器 ===== -->
  <view class="step-band" wx:if="{{totalSteps > 0}}">
    <text class="section-title">交换过程（步骤 {{currentStep}}/{{totalSteps}}）</text>

    <!-- 进度条 -->
    <slider class="warm-slider" min="0" max="{{totalSteps}}" value="{{currentStep}}" bindchange="onSliderStepChange" backgroundColor="#e6dfd8" activeColor="#cc785c" block-size="16" />

    <!-- 当前步骤说明 -->
    <view class="step-detail" wx:if="{{currentStep > 0 && currentStep <= steps.length}}">
      <view class="step-item {{steps[currentStep-1].mitm ? 'step-mitm' : ''}}">
        <text class="step-type" wx:if="{{steps[currentStep-1].type === 'sendPublicKey'}}">📤 发送公钥</text>
        <text class="step-type" wx:if="{{steps[currentStep-1].type === 'mitmIntercept'}}">🔴 MITM 拦截</text>
        <text class="step-type" wx:if="{{steps[currentStep-1].type === 'computeSharedKey'}}">🔑 计算共享密钥</text>
        <text class="step-desc">{{steps[currentStep-1].payload.explanation}}</text>
      </view>
    </view>

    <!-- 步进按钮 -->
    <view class="step-actions">
      <button class="btn-small" bindtap="onStepPrev" disabled="{{currentStep <= 0}}">◀ 上一步</button>
      <button class="btn-small" bindtap="onStepNext" disabled="{{currentStep >= totalSteps}}">下一步 ▶</button>
    </view>
  </view>

  <!-- ===== 离散对数面板（可折叠） ===== -->
  <view class="collapsible-band">
    <view class="collapsible-header" bindtap="onToggleDiscreteLog">
      <text>{{showDiscreteLog ? '▲' : '▼'}} 离散对数难度</text>
    </view>

    <view class="collapsible-body" wx:if="{{showDiscreteLog && discreteLogResult}}">
      <text class="dl-info">已知: g={{g}}, p={{p}}, A={{discreteLogResult.totalSpace > 0 ? (alice ? alice.publicKey : '?') : '?'}}</text>
      <text class="dl-info">求 a: 暴力搜索 g^? ≡ A (mod {{p}})</text>

      <view class="dl-search-result">
        <text wx:if="{{discreteLogResult.foundX !== null}}">
          找到! a = {{discreteLogResult.foundX}}，搜索次数: {{discreteLogResult.attempts}}/{{discreteLogResult.totalSpace}} ({{(discreteLogResult.attempts / discreteLogResult.totalSpace * 100).toFixed(1)}}%)
        </text>
        <text wx:else>未找到（遍历 {{discreteLogResult.attempts}} 次）</text>
      </view>

      <!-- 进度条 -->
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{discreteLogResult.totalSpace > 0 ? (discreteLogResult.attempts / discreteLogResult.totalSpace * 100).toFixed(1) + '%' : '0%'}}"></view>
      </view>

      <!-- 搜索步骤（仅显示一部分） -->
      <view class="dl-steps" wx:if="{{discreteLogResult.steps.length > 0}}">
        <view wx:for="{{discreteLogResult.steps}}" wx:key="x" class="dl-step {{item.result === (alice ? alice.publicKey : -1) ? 'dl-step-found' : ''}}">
          <text class="dl-step-x">{{g}}^{{item.x}} mod {{p}} = {{item.result}}</text>
          <text class="dl-step-mark" wx:if="{{item.result === (alice ? alice.publicKey : -1)}}">✓</text>
        </view>
      </view>

      <text class="dl-note">提示: p 增大时搜索空间指数增长。素数 p 每增加 1 位，暴力破解难度翻倍。</text>
    </view>
  </view>
</view>

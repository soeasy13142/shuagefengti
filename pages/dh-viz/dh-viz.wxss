/* ── 页面基础 ── */

.page {
  background-color: #faf9f5;
  min-height: 100vh;
  padding: 20rpx 24rpx 60rpx;
  box-sizing: border-box;
}

/* ── 卡片 ── */

.config-card {
  background-color: #efe9de;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-family: Georgia, serif;
  font-weight: 400;
  font-size: 32rpx;
  color: #141413;
  letter-spacing: -3rpx;
  margin-bottom: 20rpx;
  display: block;
}

.param-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.param-label {
  font-size: 26rpx;
  color: #6c6a64;
  min-width: 140rpx;
}

.param-picker {
  background-color: #faf9f5;
  border-radius: 12rpx;
  padding: 8rpx 20rpx;
  min-width: 120rpx;
  text-align: center;
}

.picker-value {
  font-size: 28rpx;
  color: #141413;
}

.param-helper {
  font-size: 22rpx;
  color: #6c6a64;
  margin-left: 16rpx;
}

.action-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

/* ── 按钮 ── */

.btn-primary {
  background-color: #cc785c;
  color: #faf9f5;
  font-size: 26rpx;
  border: none;
  border-radius: 16rpx;
  padding: 12rpx 32rpx;
  line-height: 1.4;
  height: auto;
  min-width: 140rpx;
}

.btn-hover {
  background-color: #a9583e;
}

.btn-secondary {
  background-color: transparent;
  color: #6c6a64;
  font-size: 26rpx;
  border: 2rpx solid #6c6a64;
  border-radius: 16rpx;
  padding: 12rpx 32rpx;
  line-height: 1.4;
  height: auto;
  min-width: 140rpx;
}

.btn-small {
  background-color: #cc785c;
  color: #faf9f5;
  font-size: 22rpx;
  border: none;
  border-radius: 12rpx;
  padding: 6rpx 16rpx;
  line-height: 1.4;
  height: auto;
  min-width: 80rpx;
}

.btn-small[disabled] {
  opacity: 0.5;
}

/* ── 双方面板 ── */

.panels-wrapper {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.panel-card {
  background-color: #efe9de;
  border-radius: 24rpx;
  padding: 24rpx;
  flex: 1;
  min-width: 300rpx;
}

.panel-alice {
  border-left: 6rpx solid #cc785c;
}

.panel-bob {
  border-left: 6rpx solid #6c8c8c;
}

.panel-title {
  font-family: Georgia, serif;
  font-weight: 400;
  font-size: 30rpx;
  color: #141413;
  letter-spacing: -3rpx;
  margin-bottom: 16rpx;
  display: block;
}

.panel-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.key-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.key-label {
  font-size: 24rpx;
  color: #6c6a64;
  min-width: 80rpx;
}

.key-input {
  background-color: #faf9f5;
  border-radius: 10rpx;
  padding: 6rpx 14rpx;
  font-size: 24rpx;
  color: #141413;
  min-width: 100rpx;
  text-align: center;
}

.key-received {
  background-color: #faf9f5;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.key-value {
  font-size: 28rpx;
  color: #141413;
  font-weight: 600;
}

.calc-row {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 8rpx 0;
}

.calc-label {
  font-size: 22rpx;
  color: #6c6a64;
}

.calc-expr {
  font-size: 24rpx;
  color: #141413;
  font-family: monospace;
}

.calc-result {
  font-size: 28rpx;
  color: #cc785c;
  font-weight: 600;
}

/* ── Eve 中间面板（MITM） ── */

.panel-eve {
  background-color: #f5e6d0;
  border: 2rpx dashed #cc4444;
  border-radius: 24rpx;
  padding: 20rpx;
  min-width: 200rpx;
  flex: 0.6;
  position: relative;
}

.eve-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #cc4444;
  display: block;
  text-align: center;
  margin-bottom: 6rpx;
}

.eve-desc {
  font-size: 22rpx;
  color: #6c6a64;
  display: block;
  text-align: center;
  margin-bottom: 10rpx;
}

.eve-detail {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  font-size: 22rpx;
  color: #141413;
}

.eve-arrow-left,
.eve-arrow-right {
  font-size: 20rpx;
  color: #cc4444;
  text-align: center;
  margin-top: 8rpx;
}

/* ── 密钥一致性 ── */

.verify-band {
  background-color: #efe9de;
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.verify-ok {
  font-size: 28rpx;
  color: #3a8a5c;
  font-weight: 600;
}

.verify-warn {
  font-size: 28rpx;
  color: #cc4444;
  font-weight: 600;
}

/* ── 步进控制 ── */

.step-band {
  background-color: #efe9de;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-family: Georgia, serif;
  font-weight: 400;
  font-size: 28rpx;
  color: #141413;
  letter-spacing: -3rpx;
  margin-bottom: 12rpx;
  display: block;
}

.warm-slider {
  margin: 8rpx 0;
}

.step-detail {
  margin: 12rpx 0;
}

.step-item {
  background-color: #faf9f5;
  border-radius: 14rpx;
  padding: 14rpx 18rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.step-mitm {
  border-left: 6rpx solid #cc4444;
}

.step-type {
  font-size: 22rpx;
  color: #6c6a64;
  font-weight: 600;
}

.step-desc {
  font-size: 24rpx;
  color: #141413;
}

.step-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 12rpx;
  justify-content: center;
}

/* ── 离散对数面板 ── */

.collapsible-band {
  background-color: #efe9de;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.collapsible-header {
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #141413;
  font-family: Georgia, serif;
  letter-spacing: -3rpx;
}

.collapsible-body {
  padding: 0 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.dl-info {
  font-size: 24rpx;
  color: #6c6a64;
}

.dl-search-result {
  font-size: 26rpx;
  color: #141413;
  font-weight: 600;
  padding: 8rpx 0;
}

.progress-bar {
  height: 16rpx;
  background-color: #e6dfd8;
  border-radius: 8rpx;
  overflow: hidden;
  margin: 8rpx 0;
}

.progress-fill {
  height: 100%;
  background-color: #cc785c;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.dl-steps {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  max-height: 400rpx;
  overflow-y: auto;
  padding: 8rpx 0;
}

.dl-step {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #6c6a64;
  font-family: monospace;
}

.dl-step-found {
  background-color: #cc785c;
  color: #faf9f5;
  font-weight: 600;
}

.dl-step-mark {
  font-weight: 700;
}

.dl-note {
  font-size: 22rpx;
  color: #6c6a64;
  font-style: italic;
  margin-top: 8rpx;
}

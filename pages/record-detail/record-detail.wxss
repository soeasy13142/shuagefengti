.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.question-num {
  font-size: 26rpx;
  color: #8e8e93;
  font-weight: 500;
}

.result-tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.tag-correct { background: rgba(7, 193, 96, 0.1); color: #07c160; }
.tag-wrong { background: rgba(230, 67, 64, 0.1); color: #e64340; }

.stem-area {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.stem-text {
  font-size: 32rpx;
  line-height: 1.7;
  color: #1a1a2e;
  font-weight: 500;
}

.options-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.option-item {
  background: #fff;
  border: 2rpx solid #f0f0f0;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.option-correct {
  border-color: #07c160;
  background: rgba(7, 193, 96, 0.06);
}

.option-wrong {
  border-color: #e64340;
  background: rgba(230, 67, 64, 0.06);
}

.option-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.judge-area {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.judge-item {
  flex: 1;
  background: #fff;
  border: 2rpx solid #f0f0f0;
  border-radius: 20rpx;
  padding: 36rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.answer-compare {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.compare-row {
  display: flex;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.compare-row:last-child { border-bottom: none; }

.compare-label {
  font-size: 26rpx;
  color: #8e8e93;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.compare-value { font-size: 26rpx; }
.text-green { color: #07c160; }
.text-red { color: #e64340; }

.explanation-area {
  background: rgba(250, 140, 22, 0.06);
  border: 2rpx solid rgba(250, 140, 22, 0.15);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.explanation-label {
  display: block;
  font-size: 22rpx;
  color: #fa8c16;
  font-weight: 700;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.explanation-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.btn-nav {
  flex: 1;
  background: #fff;
  color: #333;
  border: 2rpx solid #e8e8e8;
  border-radius: 14rpx;
  padding: 22rpx 0;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-nav[disabled] { opacity: 0.35; }

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 28rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8e8e93;
}

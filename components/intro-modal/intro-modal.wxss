/* components/intro-modal/intro-modal.wxss */

/* ── Mask ── */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.25s ease;
  pointer-events: none;
}

.modal-mask.mask-visible {
  background: rgba(0, 0, 0, 0.4);
  pointer-events: auto;
}

/* ── Card ── */
.modal-card {
  width: 580rpx;
  max-height: 80vh;
  background: #efe9de;
  border-radius: 24rpx;
  padding: 48rpx 36rpx 36rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: scale(0.92);
  opacity: 0;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.25s ease;
}

.modal-card.card-visible {
  transform: scale(1);
  opacity: 1;
}

/* ── Close Button ── */
.modal-close {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.close-icon {
  font-size: 32rpx;
  color: #8e8b82;
}

.modal-close:active .close-icon {
  color: #6c6a64;
}

/* ── Step Icon ── */
.step-icon {
  font-size: 64rpx;
  line-height: 1.2;
  margin-bottom: 16rpx;
  text-align: center;
}

/* ── Step Title ── */
.step-title {
  font-family: Georgia, serif;
  font-size: 32rpx;
  font-weight: 600;
  color: #141413;
  letter-spacing: -2rpx;
  text-align: center;
  margin-bottom: 28rpx;
  width: 100%;
}

/* ── Content Carousel ── */
.content-carousel {
  width: 100%;
  overflow: hidden;
  border-radius: 16rpx;
}

.content-track {
  display: flex;
  width: 100%;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.step-panel {
  flex: 0 0 100%;
  width: 100%;
  background: #faf9f5;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  min-height: 200rpx;
}

.step-body {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 26rpx;
  font-weight: 400;
  color: #141413;
  line-height: 1.65;
  white-space: pre-line;
  word-break: break-word;
}

/* ── Progress ── */
.step-progress {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 28rpx;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dot-inner {
  font-size: 16rpx;
  line-height: 1;
  color: #ddd7cc;
  transition: color 0.2s ease;
}

.step-dot.dot-active .dot-inner {
  color: #cc785c;
}

.step-counter {
  font-size: 24rpx;
  color: #6c6a64;
  margin-left: 8rpx;
}

/* ── Navigation ── */
.step-nav {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-top: 28rpx;
}

.nav-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-btn-text {
  font-size: 28rpx;
  font-weight: 500;
}

.nav-prev {
  background: #efe9de;
  border: 2rpx solid #ddd7cc;
}

.nav-prev:active {
  background: #ddd7cc;
}

.nav-prev .nav-btn-text {
  color: #6c6a64;
}

.nav-prev.nav-disabled {
  opacity: 0.4;
}

.nav-next {
  background: #cc785c;
}

.nav-next:active {
  background: #a9583e;
}

.nav-next-text {
  color: #faf9f5;
}
